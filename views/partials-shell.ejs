<% const unreadCount = Array.isArray(messages) ? messages.filter(m => !m.read).length : 0; %>
<header class="app-top"><a href="/" class="brand"><% if(settings.logoUrl){ %><img src="<%= settings.logoUrl %>" onerror="this.style.display='none'"><% } %><span><%= settings.siteName || 'OMTOGEL' %></span></a><a class="top-login" href="<%= settings.loginUrl || '#' %>">LOGIN</a></header>
<% if(settings.tickerText){ %><div class="ticker"><span><%= settings.tickerText %></span></div><% } %>
