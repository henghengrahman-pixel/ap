<main class="app-shell page" style="--bg:url('<%= settings.backgroundUrl || '' %>');--bgm:url('<%= settings.backgroundMobileUrl || settings.backgroundUrl || '' %>')"><%- include('../partials-shell') %><section class="page-hero"><p>PORTAL BERITA BOLA</p><h1>Berita Bola Terbaru</h1><span>Update transfer, big match, liga besar, dan kabar sepak bola pilihan.</span></section><section class="news-grid list"><% if(news.length){ news.forEach(n=>{ %><a class="news-card" href="/berita/<%= n.slug %>"><% if(n.thumbnailUrl){ %><img src="<%= n.thumbnailUrl %>" onerror="this.style.display='none'"><% } %><div><span><%= n.category %></span><h3><%= n.title %></h3><p><%= n.excerpt || '' %></p><small><%= n.author %> • <%= n.publishedAt || '' %></small></div></a><% }) } else { %><article class="empty-card">Belum ada berita aktif.</article><% } %></section><footer class="footer"><%= settings.footerText || '' %></footer></main><%- include('../bottom-nav') %>
