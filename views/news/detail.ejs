<main class="app-shell page" style="--bg:url('<%= settings.backgroundUrl || '' %>');--bgm:url('<%= settings.backgroundMobileUrl || settings.backgroundUrl || '' %>')"><%- include('../partials-shell') %><article class="article"><span class="badge"><%= article.category %></span><h1><%= article.title %></h1><div class="meta"><%= article.author %> • <%= article.publishedAt || '' %></div><% if(article.coverUrl || article.thumbnailUrl){ %><img class="cover" src="<%= article.coverUrl || article.thumbnailUrl %>" onerror="this.style.display='none'"><% } %><div class="article-content"><%- article.content %></div></article><section class="section-head"><h2>Berita Lainnya</h2></section><section class="news-grid"><% news.forEach(n=>{ %><a class="news-card" href="/berita/<%= n.slug %>"><% if(n.thumbnailUrl){ %><img src="<%= n.thumbnailUrl %>" onerror="this.style.display='none'"><% } %><div><span><%= n.category %></span><h3><%= n.title %></h3></div></a><% }) %></section><footer class="footer"><%= settings.footerText || '' %></footer></main><%- include('../bottom-nav') %>
