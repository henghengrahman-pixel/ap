<div id="loader" class="loader-screen"><div class="loader-box"><% if(settings.logoUrl){ %><img src="<%= settings.logoUrl %>" onerror="this.style.display='none'"><% } else { %><b><%= settings.siteName %></b><% } %><span></span></div></div>
<main class="app-shell" style="--bg:url('<%= settings.backgroundUrl || '' %>');--bgm:url('<%= settings.backgroundMobileUrl || settings.backgroundUrl || '' %>')">
<%- include('partials-shell') %>
<section class="hero-card"><div><p>PREMIUM SPORTSBOOK WEBVIEW</p><h1><%= settings.siteSubtitle || 'Portal Bola Premium' %></h1><small>Live score, berita bola, dan prediksi pertandingan dalam tampilan mobile app yang rapi.</small></div></section>
<% const slides=(settings.sliders||[]).filter(s=>s.active!==false && s.imageUrl); %><% if(slides.length){ %><section class="slider" data-slider><% slides.forEach((s,i)=>{ %><a class="slide <%= i===0?'active':'' %>" href="<%= s.link||'#' %>" data-open-url="<%= s.link||'#' %>"><img src="<%= s.imageUrl %>" loading="lazy" onerror="this.closest('.slide').remove()"></a><% }) %></section><% } %>
<section class="quick-grid"><% (settings.quickMenus||[]).filter(m=>m.active!==false).forEach(m=>{ %><a href="<%= m.link||'#' %>" class="quick <%= m.featured?'featured':'' %>" data-open-url="<%= m.link||'#' %>"><% if(m.imageUrl){ %><img src="<%= m.imageUrl %>" onerror="this.style.display='none'"><% } %><span><%= m.title %></span></a><% }) %></section>
<section class="section-head"><h2>Analisa Pertandingan Hari Ini</h2><p>Fokus liga besar dan pertandingan pilihan.</p></section>
<section class="match-list"><% if(predictions && predictions.length){ predictions.forEach(p=>{ %><article class="match-card"><div class="league"><span><%= p.leagueName %></span><em><%= p.status %></em></div><div class="teams"><div><% if(p.homeLogo){ %><img src="<%= p.homeLogo %>" onerror="this.style.display='none'"><% } %><b><%= p.homeName %></b></div><strong>VS</strong><div><% if(p.awayLogo){ %><img src="<%= p.awayLogo %>" onerror="this.style.display='none'"><% } %><b><%= p.awayName %></b></div></div><div class="pick-row"><span>Pick: <b><%= p.prediction %></b></span><span>Score: <b><%= p.predictedScore %></b></span><span>O/U: <b><%= p.overUnder %></b></span></div></article><% }) } else { %><article class="empty-card">Data prediksi belum diisi. Admin bisa mengisi lewat API/JSON tanpa merusak tampilan.</article><% } %></section>
<% const homeAds=(settings.ads||[]).filter(a=>a.active!==false && a.imageUrl && (a.position==='home'||!a.position)); if(homeAds.length){ %><section class="ads-row"><% homeAds.forEach(a=>{ %><a href="<%= a.link||'#' %>"><img src="<%= a.imageUrl %>" onerror="this.parentElement.remove()"></a><% }) %></section><% } %>
<section class="section-head"><h2>Berita Bola Terbaru</h2><a href="/berita">Lihat semua</a></section><section class="news-grid"><% (news||[]).forEach(n=>{ %><a class="news-card" href="/berita/<%= n.slug %>"><% if(n.thumbnailUrl){ %><img src="<%= n.thumbnailUrl %>" onerror="this.style.display='none'"><% } %><div><span><%= n.category %></span><h3><%= n.title %></h3><p><%= n.excerpt || '' %></p></div></a><% }) %></section>
<footer class="footer"><%= settings.footerText || '' %></footer>
</main><%- include('bottom-nav') %>
