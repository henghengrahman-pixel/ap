<div id="loader">
  <div class="loader-box">
    <% if(settings.logoUrl){ %>
      <img src="<%= settings.logoUrl %>" class="loader-logo" onerror="this.style.display='none'">
    <% } %>
    <div class="loader-ring"></div>
    <p>MEMUAT APLIKASI...</p>
  </div>
</div>

<div
  class="sports-app"
  style="background-image:linear-gradient(rgba(0,0,0,.78),rgba(0,0,0,.94)),url('<%= settings.backgroundUrl || '' %>');"
>
  <header class="app-header">
    <a href="/inbox" class="header-box" aria-label="Inbox">
      ✉
      <% const unreadCount = messages.filter(m=>!m.read).length; %>
      <span data-inbox-badge style="<%= unreadCount ? '' : 'display:none' %>"><%= unreadCount %></span>
    </a>

    <div class="header-logo">
      <% if(settings.logoUrl){ %>
        <img src="<%= settings.logoUrl %>" alt="<%= settings.siteName || 'OMTOGEL' %>" onerror="this.style.display='none'">
      <% } else { %>
        <h1><%= settings.siteName || 'OMTOGEL' %></h1>
      <% } %>
    </div>

    <a href="/livechat" class="livechat-pill">Live Chat</a>
  </header>

  <div class="top-running">
    <marquee><%= settings.ticker || 'SELAMAT DATANG DI OMTOGEL PREMIUM OFFICIAL • LIVECHAT ONLINE 24 JAM • BONUS MEMBER TERSEDIA' %></marquee>
  </div>

  <section class="top-slider">
    <% if(sliders.length){ %>
      <div class="slider-wrap">
        <% sliders.forEach(item=>{ %>
          <a href="<%= item.link || '#' %>" class="slider-card">
            <div class="slider-image-wrap">
              <img src="<%= item.imageUrl || item.image %>" alt="<%= item.title || 'Banner' %>" onerror="this.closest('.slider-card').style.display='none'">
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-banner">PREMIUM SPORTSBOOK</div>
    <% } %>
  </section>

  <section class="login-box">
    <p>Silahkan login untuk mulai bermain</p>
    <a href="/login" class="login-input fake-input"><b>👤</b><span>Username</span></a>
    <a href="/login" class="login-input fake-input"><b>🔒</b><span>Password</span><i>👁</i></a>
    <div class="login-links">
      <a href="/login">Versi WAP</a>
      <a href="/livechat">Lupa password?</a>
    </div>
    <a href="/login" class="login-btn">Log in</a>
    <a href="/daftar" class="register-btn">Daftar</a>
  </section>

  <% const latestMessages = messages.slice(0,2); %>
  <% if(latestMessages.length){ %>
    <section class="mini-message">
      <div class="mini-head">
        <h3>PESAN</h3>
        <a href="/inbox">SEMUA</a>
      </div>
      <% latestMessages.forEach(msg=>{ %>
        <a href="/inbox" class="mini-card">
          <small><%= msg.category || 'INFO' %></small>
          <strong><%= msg.title %></strong>
        </a>
      <% }) %>
    </section>
  <% } %>

  <footer class="app-footer">
    <p><%= settings.footer || '© OMTOGEL OFFICIAL ALL RIGHTS RESERVED' %></p>
  </footer>
</div>

<div id="menuPopup" class="menu-popup" aria-hidden="true">
  <div class="menu-popup-inner">
    <% menus.forEach((menu, index)=>{ %>
      <a
        href="<%= menu.url || '#' %>"
        class="menu-banner <%= menu.imageUrl ? 'has-image' : '' %>"
        style="<%= menu.imageUrl ? `background-image:url('${menu.imageUrl}')` : '' %>"
      >
        <div class="menu-banner-glow"></div>
        <div class="menu-banner-content">
          <div class="menu-banner-icon"><%= menu.icon || '◆' %></div>
          <div>
            <h3><%= menu.title || 'MENU' %></h3>
            <p><%= menu.subtitle || 'Klik untuk membuka halaman' %></p>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</div>

<nav class="bottom-nav">
  <button type="button" id="openMenu" class="bottom-item">
    <i>☰</i>
    <span>Menu</span>
  </button>

  <a href="/livedraw" class="bottom-item">
    <i>▦</i>
    <span>Live Draw</span>
  </a>

  <a href="/whatsapp" class="bottom-center" aria-label="WhatsApp">
    <i>♠</i>
  </a>

  <a href="/inbox" class="bottom-item">
    <i>✉</i>
    <span>Inbox <em data-inbox-badge style="<%= unreadCount ? '' : 'display:none' %>"><%= unreadCount %></em></span>
  </a>
</nav>

<script>
(function(){
  const loader = document.getElementById('loader');
  window.addEventListener('load', function(){
    if(loader){ setTimeout(function(){ loader.classList.add('hide'); }, 450); }
  });

  const openMenu = document.getElementById('openMenu');
  const menuPopup = document.getElementById('menuPopup');

  function toggleMenu(force){
    if(!menuPopup) return;
    const active = typeof force === 'boolean' ? force : !menuPopup.classList.contains('active');
    menuPopup.classList.toggle('active', active);
    menuPopup.setAttribute('aria-hidden', active ? 'false' : 'true');
    document.body.classList.toggle('menu-open', active);
  }

  if(openMenu){
    openMenu.addEventListener('click', function(){ toggleMenu(); });
  }

  if(menuPopup){
    menuPopup.addEventListener('click', function(e){
      if(e.target === menuPopup){ toggleMenu(false); }
    });
  }

  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape'){ toggleMenu(false); }
  });
})();
</script>
