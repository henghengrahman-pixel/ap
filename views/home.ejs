<%
const slides = Array.isArray(settings?.sliders) ? settings.sliders.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const buttons = Array.isArray(settings?.buttons) ? settings.buttons.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const navs = Array.isArray(settings?.bottomNav) ? settings.bottomNav.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const fallbackBanner = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="900" height="320" viewBox="0 0 900 320"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#050505"/><stop offset=".5" stop-color="#2b2b2b"/><stop offset="1" stop-color="#050505"/></linearGradient></defs><rect width="900" height="320" fill="url(#g)"/><text x="450" y="142" text-anchor="middle" font-family="Arial" font-size="54" font-weight="900" fill="#f5f5f5">OMTOGEL</text><text x="450" y="205" text-anchor="middle" font-family="Arial" font-size="26" font-weight="700" fill="#cfcfcf">atur slider promo dari admin</text></svg>`);
const navMap = {
  home: { icon:'fa-solid fa-house', title:'HOME' },
  daftar: { icon:'fa-solid fa-user-plus', title:'DAFTAR' },
  whatsapp: { icon:'fa-brands fa-whatsapp', title:'WHATSAPP' },
  livechat: { icon:'fa-regular fa-comments', title:'LIVE CHAT' }
};
%>
<div id="loader" class="loader-screen">
  <div class="loader-box">
    <% if(settings?.loaderLogoUrl || settings?.logoUrl){ %><img src="<%= settings.loaderLogoUrl || settings.logoUrl %>" alt="Loader" onerror="this.style.display='none'"><% } else { %><strong><%= settings?.siteName || 'OMTOGEL' %></strong><% } %>
    <div class="loader-ring"></div>
    <p><%= settings?.loaderText || 'MEMUAT APLIKASI...' %></p>
  </div>
</div>
<div class="app-home" style="--bg-main:url('<%= settings?.backgroundMain || '' %>')">
  <header class="app-logo-head">
    <% if(settings?.logoUrl){ %><img src="<%= settings.logoUrl %>" alt="<%= settings?.siteName || 'OMTOGEL' %>" onerror="this.style.display='none'"><% } else { %><h1><%= settings?.siteName || 'OMTOGEL' %></h1><% } %>
  </header>
  <main class="mobile-shell">
    <section class="promo-slider">
      <div class="slider-window"><div class="slides-track" id="slidesTrack">
        <% (slides.length ? slides : [{ imageUrl:fallbackBanner, link:'#', title:'Banner' }]).forEach((slide)=>{ %>
          <a class="slide-item" href="<%= slide.link || '#' %>" target="<%= slide.link?.startsWith('http') ? '_blank' : '_self' %>"><img src="<%= slide.imageUrl || fallbackBanner %>" alt="<%= slide.title || 'Banner' %>" loading="lazy" onerror="this.src='<%= fallbackBanner %>'"></a>
        <% }) %>
      </div></div>
    </section>
    <section class="main-buttons">
      <% buttons.forEach((btn)=>{ %>
        <a class="app-btn <%= btn.color === 'red' ? 'btn-red' : 'btn-silver' %>" href="<%= btn.link || '#' %>" target="<%= btn.link?.startsWith('http') ? '_blank' : '_self' %>"><% if(btn.icon){ %><i class="<%= btn.icon %>"></i><% } %><span><%= btn.title || 'MENU' %></span></a>
      <% }) %>
    </section>
  </main>
  <footer class="app-footer"><%= settings?.footerText || '' %></footer>
  <nav class="fixed-bottom-nav">
    <% navs.forEach((nav)=>{ const meta = navMap[nav.key] || { icon:'fa-solid fa-circle', title:'MENU' }; %>
      <% if(nav.key === 'home'){ %>
        <button type="button" class="nav-entry nav-btn" onclick="window.location.href='/'"><i class="<%= meta.icon %>"></i><span><%= nav.title || meta.title %></span></button>
      <% } else if(nav.key === 'daftar'){ %>
        <a href="<%= nav.link || '#' %>" class="nav-entry center-nav" target="_blank"><div class="center-circle"><i class="<%= meta.icon %>"></i></div><span><%= nav.title || meta.title %></span></a>
      <% } else { %>
        <a href="<%= nav.link || '#' %>" class="nav-entry" target="_blank"><i class="<%= meta.icon %>"></i><span><%= nav.title || meta.title %></span></a>
      <% } %>
    <% }) %>
  </nav>
</div>
<% if(settings?.popupActive && settings?.popupImageUrl){ %>
<div class="welcome-popup" id="welcomePopup"><a href="<%= settings.popupLink || '#' %>"><img src="<%= settings.popupImageUrl %>" alt="Popup"></a><button type="button" id="closePopup">×</button></div>
<% } %>
<script>
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader')?.classList.add('hide'),450));
(()=>{const track=document.getElementById('slidesTrack');if(!track)return;const items=track.querySelectorAll('.slide-item');if(items.length<=1)return;let index=0;setInterval(()=>{index=(index+1)%items.length;track.style.transform=`translateX(-${index*100}%)`;},3300);})();
(()=>{const popup=document.getElementById('welcomePopup');if(!popup)return;setTimeout(()=>popup.classList.add('show'),Number('<%= settings?.popupTimer || 1200 %>'));document.getElementById('closePopup')?.addEventListener('click',()=>popup.remove());})();
</script>
