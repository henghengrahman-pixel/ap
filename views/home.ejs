<div id="loader">
  <div class="loader-box">
    <% if(settings.logoUrl){ %>
      <img
        src="<%= settings.logoUrl %>"
        class="loader-logo"
        onerror="this.style.display='none'"
      >
    <% } %>

    <div class="loader-ring"></div>

    <p>MEMUAT APLIKASI...</p>
  </div>
</div>

<div
  class="sports-app"
  style="
    background-image:
      linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.96)),
      url('<%= settings.backgroundUrl || '' %>');
  "
>

<header class="app-header">

  <a href="/inbox" class="header-box">

    ✉

    <% const unreadCount = messages.filter(m=>!m.read).length; %>

    <% if(unreadCount){ %>
      <span><%= unreadCount %></span>
    <% } %>

  </a>

  <div class="header-logo">

    <% if(settings.logoUrl){ %>

      <img
        src="<%= settings.logoUrl %>"
        alt="<%= settings.siteName %>"
        onerror="this.style.display='none'"
      >

    <% } else { %>

      <h1><%= settings.siteName || 'OMTOGEL' %></h1>

    <% } %>

  </div>

  <a href="/livechat" class="header-box">
    ☏
  </a>

</header>

<div class="top-running">
  <marquee>
    <%= settings.ticker || 'SELAMAT DATANG DI OMTOGEL PREMIUM OFFICIAL • LIVECHAT ONLINE 24 JAM • BONUS MEMBER TERSEDIA' %>
  </marquee>
</div>

<section class="top-slider">

  <% if(sliders.length){ %>

    <div class="slider-wrap">

      <% sliders.forEach(item=>{ %>

        <a
          href="<%= item.link || '#' %>"
          class="slider-card"
        >

          <div class="slider-image-wrap">

            <img
              src="<%= item.imageUrl || item.image %>"
              alt="<%= item.title || 'Banner' %>"
              onerror="this.closest('.slider-card').style.display='none'"
            >

          </div>

        </a>

      <% }) %>

    </div>

  <% } else { %>

    <div class="empty-banner">
      PREMIUM SPORTSBOOK
    </div>

  <% } %>

</section>

<section class="auth-menu">

  <a href="/login" class="auth-card silver-card">

    <div class="auth-icon">◎</div>

    <div class="auth-text">
      <strong>LOGIN</strong>
      <small>MEMBER AREA</small>
    </div>

  </a>

  <a href="/daftar" class="auth-card gold-card">

    <div class="auth-icon">✚</div>

    <div class="auth-text">
      <strong>DAFTAR</strong>
      <small>AKUN BARU</small>
    </div>

  </a>

</section>

<section class="main-menu">

  <div class="main-grid">

    <% menus.forEach(menu=>{ %>

      <% if(menu.title !== 'LOGIN' && menu.title !== 'DAFTAR'){ %>

        <a
          href="<%= menu.url || '#' %>"
          class="main-card"
        >

          <div class="main-icon">
            <%= menu.icon || '✦' %>
          </div>

          <div class="main-info">
            <strong><%= menu.title %></strong>
          </div>

        </a>

      <% } %>

    <% }) %>

  </div>

</section>

<% const latestMessages = messages.slice(0,2); %>

<% if(latestMessages.length){ %>

<section class="mini-message">

  <div class="mini-head">

    <h3>PESAN</h3>

    <a href="/inbox">
      SEMUA
    </a>

  </div>

  <% latestMessages.forEach(msg=>{ %>

    <a href="/inbox" class="mini-card">

      <small>
        <%= msg.category || 'INFO' %>
      </small>

      <strong>
        <%= msg.title %>
      </strong>

    </a>

  <% }) %>

</section>

<% } %>

<footer class="app-footer">

  <p>
    <%= settings.footer || '© OMTOGEL OFFICIAL ALL RIGHTS RESERVED' %>
  </p>

</footer>

<nav class="mobile-nav">

  <a href="/" class="active">
    <i>⌂</i>
    <span>HOME</span>
  </a>

  <a href="/daftar">
    <i>◎</i>
    <span>DAFTAR</span>
  </a>

  <a href="/whatsapp">
    <i>◉</i>
    <span>WHATSAPP</span>
  </a>

  <a href="/livechat">
    <i>✦</i>
    <span>LIVECHAT</span>
  </a>

</nav>

</div>

<script>

window.addEventListener(
  'load',
  () => {

    const loader =
      document.getElementById(
        'loader'
      );

    if(loader){

      setTimeout(() => {

        loader.style.opacity = '0';

        loader.style.visibility =
          'hidden';

      }, 700);

    }

  }
);

</script>
