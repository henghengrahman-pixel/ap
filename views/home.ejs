<% const unreadCount = messages.filter(m => !m.read).length; %>
<% const fallbackImg = 'data:image/svg+xml;utf8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 320"><defs><linearGradient id="g" x1="0" x2="1"><stop stop-color="#050505"/><stop offset=".55" stop-color="#1b1b1b"/><stop offset="1" stop-color="#050505"/></linearGradient></defs><rect width="900" height="320" fill="url(#g)"/><rect x="18" y="18" width="864" height="284" rx="34" fill="none" stroke="#cfd2d6" stroke-width="4"/><text x="50" y="145" fill="#f4f4f4" font-family="Arial" font-size="54" font-weight="900">OMTOGEL MENU</text><text x="54" y="205" fill="#bfc3c8" font-family="Arial" font-size="30" font-weight="700">Atur gambar, judul dan link dari admin</text></svg>'); %>
<% const menuCards = Array.isArray(settings.menuCards) ? settings.menuCards : []; %>

<div id="loader" class="loader-screen">
  <div class="loader-box">
    <% if(settings.logoUrl){ %>
      <img src="<%= settings.logoUrl %>" alt="<%= settings.siteName || 'OMTOGEL' %>" onerror="this.style.display='none'">
    <% } else { %>
      <strong><%= settings.siteName || 'OMTOGEL' %></strong>
    <% } %>
    <div class="loader-ring"></div>
    <p>MEMUAT APLIKASI...</p>
  </div>
</div>

<div class="webview-app">
  <main class="webview-area">
    <iframe
      id="mainFrame"
      src="<%= settings.mainWebviewUrl || '/blank-frame' %>"
      title="<%= settings.siteName || 'OMTOGEL' %>"
      loading="eager"
      referrerpolicy="no-referrer-when-downgrade"
      allow="clipboard-read; clipboard-write; fullscreen; payment; autoplay"
    ></iframe>
  </main>

  <div id="popupBackdrop" class="popup-backdrop" aria-hidden="true"></div>
  <section id="menuPopup" class="menu-popup" aria-label="Menu popup">
    <div class="popup-handle"></div>
    <div class="popup-head">
      <div>
        <b>MENU UTAMA</b>
        <span>Pilih menu cepat</span>
      </div>
      <button type="button" id="closeMenuBtn" aria-label="Tutup menu"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="menu-grid">
      <% for(let i=0;i<8;i++){ const card = menuCards[i] || {}; %>
        <a href="<%= card.link || '#' %>" data-menu-link="<%= card.link || '#' %>" class="menu-card">
          <img src="<%= card.image || fallbackImg %>" alt="<%= card.title || ('Menu ' + (i+1)) %>" loading="lazy" onerror="this.src='<%= fallbackImg %>'">
          <div class="menu-card-copy">
            <h3><%= card.title || ('MENU ' + (i+1)) %></h3>
            <p><%= card.desc || 'Atur dari admin' %></p>
          </div>
        </a>
      <% } %>
    </div>
  </section>

  <nav class="bottom-nav" aria-label="Menu bawah">
    <button type="button" id="openMenuBtn" class="bottom-item">
      <i class="fa-solid fa-bars nav-icon"></i>
      <span class="nav-text">MENU</span>
    </button>
    <button type="button" class="bottom-item" data-frame-url="<%= settings.liveDrawUrl || '#' %>">
      <i class="fa-solid fa-table-cells-large nav-icon"></i>
      <span class="nav-text">LIVEDRAW</span>
    </button>
    <button type="button" class="bottom-logo" id="homeFrame" aria-label="Home">
      <% if(settings.logoUrl){ %><img src="<%= settings.logoUrl %>" alt="Home" onerror="this.outerHTML='<i class=&quot;fa-solid fa-house&quot;></i>'"><% } else { %><i class="fa-solid fa-house"></i><% } %>
    </button>
    <button type="button" class="bottom-item" data-frame-url="<%= settings.whatsappUrl || '#' %>">
      <i class="fa-brands fa-whatsapp nav-icon"></i>
      <span class="nav-text">WHATSAPP</span>
    </button>
    <button type="button" class="bottom-item" data-frame-url="<%= settings.inboxUrl || '/inbox-frame' %>">
      <i class="fa-solid fa-envelope nav-icon"></i>
      <span class="nav-text">INBOX</span>
      <em data-inbox-badge style="<%= unreadCount ? '' : 'display:none' %>"><%= unreadCount %></em>
    </button>
  </nav>
</div>

<script>
(function(){
  const HOME_URL = '<%- JSON.stringify(settings.mainWebviewUrl || '/blank-frame').slice(1,-1) %>';
  const loader = document.getElementById('loader');
  const frame = document.getElementById('mainFrame');
  const menuPopup = document.getElementById('menuPopup');
  const popupBackdrop = document.getElementById('popupBackdrop');
  const openMenuBtn = document.getElementById('openMenuBtn');
  const closeMenuBtn = document.getElementById('closeMenuBtn');
  const homeFrame = document.getElementById('homeFrame');
  const frameButtons = document.querySelectorAll('[data-frame-url]');
  const cardLinks = document.querySelectorAll('[data-menu-link]');

  function usable(url){ return url && url !== '#'; }
  function openPopup(){ menuPopup.classList.add('active'); popupBackdrop.classList.add('active'); openMenuBtn.classList.add('active'); }
  function closePopup(){ menuPopup.classList.remove('active'); popupBackdrop.classList.remove('active'); openMenuBtn.classList.remove('active'); }
  function setActive(btn){ document.querySelectorAll('.bottom-item').forEach(x => x.classList.remove('active')); if(btn) btn.classList.add('active'); }
  function loadFrame(url){ if(usable(url)){ frame.src = url; } }

  openMenuBtn.addEventListener('click', function(){ menuPopup.classList.contains('active') ? closePopup() : openPopup(); });
  closeMenuBtn.addEventListener('click', closePopup);
  popupBackdrop.addEventListener('click', closePopup);

  frameButtons.forEach(function(btn){
    btn.addEventListener('click', function(){ closePopup(); setActive(this); loadFrame(this.dataset.frameUrl); });
  });

  cardLinks.forEach(function(link){
    link.addEventListener('click', function(e){
      const url = this.dataset.menuLink;
      if(usable(url)){ e.preventDefault(); loadFrame(url); closePopup(); setActive(null); }
    });
  });

  homeFrame.addEventListener('click', function(){ closePopup(); setActive(null); loadFrame(HOME_URL); });
  frame.addEventListener('load', function(){ if(loader){ loader.classList.add('hide'); } });
  setTimeout(function(){ if(loader){ loader.classList.add('hide'); } }, 1800);
  if(location.hash === '#inbox'){ loadFrame('<%= settings.inboxUrl || '/inbox-frame' %>'); }
})();
</script>
