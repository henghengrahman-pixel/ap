<% const activeSlides = (settings.sliders || []).filter(x => x.active !== false); %>
<% const activeButtons = (settings.buttons || []).filter(x => x.active !== false); %>
<% const activeNav = (settings.bottomNav || []).filter(x => x.active !== false); %>
<% const fallbackBanner = 'data:image/svg+xml;utf8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 320"><defs><linearGradient id="g" x1="0" x2="1"><stop stop-color="#111"/><stop offset=".5" stop-color="#555"/><stop offset="1" stop-color="#111"/></linearGradient></defs><rect width="900" height="320" fill="black"/><rect x="20" y="20" width="860" height="280" rx="42" fill="url(#g)" stroke="#bbb" stroke-width="4"/><text x="450" y="150" text-anchor="middle" fill="#fff" font-family="Arial" font-size="54" font-weight="900">OMTOGEL</text><text x="450" y="205" text-anchor="middle" fill="#ddd" font-family="Arial" font-size="26" font-weight="700">Atur banner slider dari admin</text></svg>'); %>
<div id="loader" class="loader-screen" style="<%= settings.backgroundLoading ? `background-image:linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.96)),url('${settings.backgroundLoading}')` : '' %>">
  <div class="loader-box">
    <% if(settings.loaderLogoUrl || settings.logoUrl){ %><img src="<%= settings.loaderLogoUrl || settings.logoUrl %>" alt="loader" onerror="this.style.display='none'"><% } else { %><strong><%= settings.siteName || 'OMTOGEL' %></strong><% } %>
    <div class="loader-ring"></div><p><%= settings.loaderText || 'MEMUAT APLIKASI...' %></p>
  </div>
</div>
<div class="app-home" style="--bg-main:url('<%= settings.backgroundMain || '' %>');--bg-mobile:url('<%= settings.backgroundMobile || settings.backgroundMain || '' %>');--bg-desktop:url('<%= settings.backgroundDesktop || settings.backgroundMain || '' %>');--bg-footer:url('<%= settings.backgroundFooter || '' %>');--bg-navbar:url('<%= settings.backgroundNavbar || '' %>')">
  <header class="app-logo-head">
    <% if(settings.logoUrl){ %><img src="<%= settings.logoUrl %>" alt="<%= settings.siteName || 'Logo' %>" onerror="this.outerHTML='<h1><%= settings.siteName || 'OMTOGEL' %></h1>'"><% } else { %><h1><%= settings.siteName || 'OMTOGEL' %></h1><% } %>
  </header>
  <main class="mobile-shell">
    <section class="promo-slider" aria-label="Slider promo">
      <div class="slides-track" id="slidesTrack">
        <% (activeSlides.length ? activeSlides : [{imageUrl:fallbackBanner,link:'#',title:'OMTOGEL'}]).forEach(slide => { %>
          <a class="slide-item" href="<%= slide.link || '#' %>">
            <img src="<%= slide.imageUrl || fallbackBanner %>" alt="<%= slide.title || 'Promo' %>" onerror="this.src='<%= fallbackBanner %>'">
          </a>
        <% }) %>
      </div>
    </section>
    <section class="main-buttons">
      <% activeButtons.forEach(btn => { %>
        <a class="app-btn <%= btn.color === 'red' ? 'btn-red' : 'btn-silver' %>" href="<%= btn.link || '#' %>">
          <% if(btn.icon){ %><i class="<%= btn.icon %>"></i><% } %><span><%= btn.title %></span>
        </a>
      <% }) %>
    </section>
  </main>
  <footer class="app-footer"><%= settings.footerText || '' %></footer>
  <nav class="fixed-bottom-nav" aria-label="Bottom navigation">
    <% activeNav.forEach(nav => { %>
      <a href="<%= nav.link || '#' %>" class="nav-entry" style="--active-color:<%= nav.colorActive || '#d21717' %>">
        <i class="<%= nav.icon || 'fa-solid fa-circle' %>"></i><span><%= nav.title || 'MENU' %></span>
      </a>
    <% }) %>
  </nav>
</div>
<% if(settings.popupActive && settings.popupImageUrl){ %>
<div class="welcome-popup" id="welcomePopup" style="--popup-bg:url('<%= settings.backgroundPopup || '' %>')">
  <a href="<%= settings.popupLink || '#' %>"><img src="<%= settings.popupImageUrl %>" alt="Popup"></a>
  <button type="button" id="closePopup">×</button>
</div>
<% } %>
<script>
(function(){
  const loader=document.getElementById('loader');
  setTimeout(()=>loader&&loader.classList.add('hide'),900);
  const track=document.getElementById('slidesTrack');
  if(track && track.children.length>1){let i=0;setInterval(()=>{i=(i+1)%track.children.length;track.scrollTo({left:i*track.clientWidth,behavior:'smooth'});},3200);}
  const pop=document.getElementById('welcomePopup');
  if(pop){setTimeout(()=>pop.classList.add('show'), Number('<%= settings.popupTimer || 1200 %>') || 1200);document.getElementById('closePopup').onclick=()=>pop.remove();}
})();
</script>
