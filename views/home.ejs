<%
const slides = Array.isArray(settings?.sliders)
? settings.sliders
.filter(x => x && x.active !== false)
.sort((a,b)=>(a.order||0)-(b.order||0))
: [];

const buttons = Array.isArray(settings?.buttons)
? settings.buttons
.filter(x => x && x.active !== false)
.sort((a,b)=>(a.order||0)-(b.order||0))
: [];

const navs = Array.isArray(settings?.bottomNav)
? settings.bottomNav
.filter(x => x && x.active !== false)
.sort((a,b)=>(a.order||0)-(b.order||0))
: [];

const featureCards = Array.isArray(settings?.featureCards)
? settings.featureCards
.filter(x => x && x.active !== false)
.sort((a,b)=>(a.order||0)-(b.order||0))
: [];

const fallbackBanner =
'data:image/svg+xml;charset=UTF-8,' +
encodeURIComponent(`
<svg xmlns="http://www.w3.org/2000/svg" width="900" height="320">
<rect width="100%" height="100%" fill="#000"/>
<text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="#fff" font-size="42" font-family="Arial">OMTOGEL</text>
</svg>
`);

function navIcon(key){

  switch(key){

    case 'home':
      return 'fa-solid fa-house';

    case 'daftar':
      return 'fa-solid fa-user-plus';

    case 'whatsapp':
      return 'fa-brands fa-whatsapp';

    case 'livechat':
      return 'fa-solid fa-headset';

    default:
      return 'fa-solid fa-circle';
  }

}
%>

<div id="loader" class="loader-screen">

  <div class="loader-box">

    <% if(settings?.loaderLogoUrl || settings?.logoUrl){ %>

      <img
        src="<%= settings.loaderLogoUrl || settings.logoUrl %>"
        alt="Loader"
        onerror="this.style.display='none'"
      >

    <% } else { %>

      <strong>
        <%= settings?.siteName || 'OMTOGEL' %>
      </strong>

    <% } %>

    <div class="loader-ring"></div>

    <p>
      <%= settings?.loaderText || 'MEMUAT APLIKASI...' %>
    </p>

  </div>

</div>

<div
  class="app-home"
  style="
    --bg-main:url('<%= settings?.backgroundMain || '' %>');
    --bg-navbar:url('<%= settings?.backgroundNavbar || '' %>')
  "
>

<header class="app-logo-head">

  <% if(settings?.logoUrl){ %>

    <img
      src="<%= settings.logoUrl %>"
      alt="<%= settings?.siteName || 'OMTOGEL' %>"
      onerror="this.style.display='none'"
    >

  <% } else { %>

    <h1>
      <%= settings?.siteName || 'OMTOGEL' %>
    </h1>

  <% } %>

</header>

<main class="mobile-shell">

  <!-- SLIDER -->
  <section class="promo-slider">

    <div class="slider-window">

      <div
        class="slides-track"
        id="slidesTrack"
      >

        <%

        (
          slides.length
          ? slides
          : [{
              imageUrl:fallbackBanner,
              link:'#'
            }]
        )

        .forEach((slide)=>{

        %>

        <a
          class="slide-item"
          href="<%= slide.link || '#' %>"
          target="<%= slide.link?.startsWith('http') ? '_blank' : '_self' %>"
        >

          <img
            src="<%= slide.imageUrl || fallbackBanner %>"
            alt="<%= slide.title || 'Banner' %>"
            loading="lazy"
            onerror="this.src='<%= fallbackBanner %>'"
          >

        </a>

        <% }) %>

      </div>

    </div>

  </section>

  <!-- MENU -->
  <section class="main-buttons">

    <% buttons.forEach((btn)=>{ %>

      <a
        class="
          app-btn
          <%= btn.color === 'red'
          ? 'btn-red'
          : 'btn-silver' %>
        "
        href="<%= btn.link || '#' %>"
        target="<%= btn.link?.startsWith('http') ? '_blank' : '_self' %>"
      >

        <% if(btn.icon){ %>

          <i class="<%= btn.icon %>"></i>

        <% } %>

        <span>
          <%= btn.title || 'MENU' %>
        </span>

      </a>

    <% }) %>

  </section>

  <!-- FEATURE -->
  <% if(featureCards.length){ %>

  <section class="feature-section">

    <% featureCards.forEach((card)=>{ %>

      <a
        href="<%= card.link || '#' %>"
        class="feature-card"
      >

        <% if(card.image){ %>

          <img
            src="<%= card.image %>"
            alt="<%= card.title || 'Info' %>"
            loading="lazy"
          >

        <% } %>

        <span>
          <%= card.title || 'INFO' %>
        </span>

      </a>

    <% }) %>

  </section>

  <% } %>

</main>

<footer class="app-footer">

  <%= settings?.footerText || '' %>

</footer>

<!-- NAVBAR -->
<nav class="fixed-bottom-nav">

  <% navs.forEach((nav)=>{ %>

    <% if(nav.key === 'home'){ %>

      <button
        type="button"
        class="nav-entry nav-btn"
        onclick="window.location.href='/'"
      >

        <i class="fa-solid fa-house"></i>

        <span>
          <%= nav.title || 'HOME' %>
        </span>

      </button>

    <% } else if(nav.key === 'daftar'){ %>

      <a
        href="<%= nav.link || '#' %>"
        class="nav-entry center-nav"
        target="_blank"
      >

        <div class="center-circle">

          <i class="fa-solid fa-user-plus"></i>

        </div>

        <span>
          <%= nav.title || 'DAFTAR' %>
        </span>

      </a>

    <% } else if(nav.key === 'whatsapp'){ %>

      <a
        href="<%= nav.link || '#' %>"
        class="nav-entry"
        target="_blank"
      >

        <i class="fa-brands fa-whatsapp"></i>

        <span>
          <%= nav.title || 'WHATSAPP' %>
        </span>

      </a>

    <% } else if(nav.key === 'livechat'){ %>

      <a
        href="<%= nav.link || '#' %>"
        class="nav-entry"
        target="_blank"
      >

        <i class="fa-solid fa-headset"></i>

        <span>
          <%= nav.title || 'LIVECHAT' %>
        </span>

      </a>

    <% } %>

  <% }) %>

</nav>
</div>

<!-- POPUP -->
<% if(settings?.popupActive && settings?.popupImageUrl){ %>

<div
  class="welcome-popup"
  id="welcomePopup"
>

  <a href="<%= settings.popupLink || '#' %>">

    <img
      src="<%= settings.popupImageUrl %>"
      alt="Popup"
    >

  </a>

  <button
    type="button"
    id="closePopup"
  >
    ×
  </button>

</div>

<% } %>

<script>

/*
==========================
LOADER
==========================
*/

window.addEventListener(
  'load',
  () => {

    setTimeout(() => {

      document
      .getElementById('loader')
      ?.classList.add('hide');

    }, 500);

  }
);

/*
==========================
SLIDER
==========================
*/

(() => {

  const track =
    document.getElementById(
      'slidesTrack'
    );

  if(!track) return;

  const items =
    track.querySelectorAll(
      '.slide-item'
    );

  if(items.length <= 1) return;

  let index = 0;

  setInterval(() => {

    index =
      (index + 1)
      % items.length;

    track.style.transform =
      `translateX(-${index * 100}%)`;

  }, 3200);

})();

/*
==========================
POPUP
==========================
*/

(() => {

  const popup =
    document.getElementById(
      'welcomePopup'
    );

  if(!popup) return;

  setTimeout(() => {

    popup.classList.add('show');

  }, Number(
    '<%= settings?.popupTimer || 1200 %>'
  ));

  document
  .getElementById('closePopup')
  ?.addEventListener(
    'click',
    () => popup.remove()
  );

})();

</script>
