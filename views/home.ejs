<%
const slides = Array.isArray(settings?.sliders)
  ? settings.sliders
      .filter(item => item?.active !== false)
      .sort((a,b)=>(a.order||0)-(b.order||0))
  : [];

const buttons = Array.isArray(settings?.buttons)
  ? settings.buttons
      .filter(item => item?.active !== false)
      .sort((a,b)=>(a.order||0)-(b.order||0))
  : [];

const navs = Array.isArray(settings?.bottomNav)
  ? settings.bottomNav
      .filter(item => item?.active !== false)
      .sort((a,b)=>(a.order||0)-(b.order||0))
  : [];

const fallbackBanner =
'https://dummyimage.com/900x320/111111/ffffff&text=OMTOGEL';
%>

<div
  id="loader"
  class="loader-screen"
  style="
    background-image:
    linear-gradient(
      rgba(0,0,0,.90),
      rgba(0,0,0,.96)
    )
    <% if(settings?.backgroundLoading){ %>,
    url('<%= settings.backgroundLoading %>')
    <% } %>;
  "
>

  <div class="loader-box">

    <% if(settings?.loaderLogoUrl || settings?.logoUrl){ %>

      <img
        src="<%= settings.loaderLogoUrl || settings.logoUrl %>"
        alt="Loader"
        onerror="this.style.display='none'"
      >

    <% } else { %>

      <strong>
        <%= settings?.siteName || 'OMTOGEL' %>
      </strong>

    <% } %>

    <div class="loader-ring"></div>

    <p>
      <%= settings?.loaderText || 'MEMUAT APLIKASI...' %>
    </p>

  </div>

</div>

<div
  class="app-home"
  style="
    --bg-main:
    url('<%= settings?.backgroundMain || '' %>');

    --bg-footer:
    url('<%= settings?.backgroundFooter || '' %>');

    --bg-navbar:
    url('<%= settings?.backgroundNavbar || '' %>');
  "
>

  <header class="app-logo-head">

    <% if(settings?.logoUrl){ %>

      <img
        src="<%= settings.logoUrl %>"
        alt="<%= settings?.siteName || 'OMTOGEL' %>"
        onerror="this.style.display='none'"
      >

    <% } else { %>

      <h1>
        <%= settings?.siteName || 'OMTOGEL' %>
      </h1>

    <% } %>

  </header>

  <main class="mobile-shell">

    <section class="promo-slider">

      <div class="slider-window">

        <div
          class="slides-track"
          id="slidesTrack"
        >

          <% (slides.length ? slides : [{imageUrl:fallbackBanner,link:'#'}]).forEach((slide)=>{ %>

            <a
              class="slide-item"
              href="<%= slide.link || '#' %>"
            >

              <img
                src="<%= slide.imageUrl || fallbackBanner %>"
                alt="Banner"
                loading="lazy"
                onerror="this.src='<%= fallbackBanner %>'"
              >

            </a>

          <% }) %>

        </div>

      </div>

    </section>

    <section class="main-buttons">

      <% buttons.forEach((btn)=>{ %>

        <a
          class="
            app-btn
            <%= btn.color === 'red'
              ? 'btn-red'
              : 'btn-silver'
            %>
          "
          href="<%= btn.link || '#' %>"
        >

          <% if(btn.icon){ %>

            <i class="<%= btn.icon %>"></i>

          <% } %>

          <span>
            <%= btn.title || 'MENU' %>
          </span>

        </a>

      <% }) %>

    </section>

  </main>

  <footer class="app-footer">

    <%= settings?.footerText || '' %>

  </footer>

  <nav class="fixed-bottom-nav">

    <% navs.forEach((nav)=>{ %>

      <a
        href="<%= nav.link || '#' %>"
        class="nav-entry"
        style="
          --active-color:
          <%= nav.colorActive || '#d21717' %>;
        "
      >

        <i class="<%= nav.icon || 'fa-solid fa-circle' %>"></i>

        <span>
          <%= nav.title || 'MENU' %>
        </span>

      </a>

    <% }) %>

  </nav>

</div>

<% if(settings?.popupActive && settings?.popupImageUrl){ %>

<div
  class="welcome-popup"
  id="welcomePopup"
>

  <a href="<%= settings.popupLink || '#' %>">

    <img
      src="<%= settings.popupImageUrl %>"
      alt="Popup"
    >

  </a>

  <button
    type="button"
    id="closePopup"
  >
    ×
  </button>

</div>

<% } %>

<script>

window.addEventListener(
  'load',
  () => {

    const loader =
      document.getElementById('loader');

    setTimeout(() => {

      if(loader){

        loader.classList.add('hide');

      }

    }, 700);

  }
);

(() => {

  const track =
    document.getElementById('slidesTrack');

  if(!track) return;

  const items =
    track.querySelectorAll('.slide-item');

  if(items.length <= 1) return;

  let index = 0;

  function updateSlider(){

    track.style.transform =
      `translateX(-${index * 100}%)`;

  }

  setInterval(() => {

    index++;

    if(index >= items.length){

      index = 0;

    }

    updateSlider();

  }, 3200);

})();

(() => {

  const popup =
    document.getElementById('welcomePopup');

  if(!popup) return;

  setTimeout(() => {

    popup.classList.add('show');

  }, Number('<%= settings?.popupTimer || 1200 %>'));

  const close =
    document.getElementById('closePopup');

  if(close){

    close.onclick = () => {

      popup.remove();

    };

  }

})();

</script>
