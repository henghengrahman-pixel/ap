<%
const slides = Array.isArray(settings?.sliders) ? settings.sliders.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const buttons = Array.isArray(settings?.buttons) ? settings.buttons.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const navs = Array.isArray(settings?.bottomNav) ? settings.bottomNav.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const featureCards = Array.isArray(settings?.featureCards) ? settings.featureCards.filter(x => x && x.active !== false).sort((a,b)=>(a.order||0)-(b.order||0)) : [];
const fallbackBanner = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="900" height="320" viewBox="0 0 900 320"><defs><linearGradient id="g" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#050505"/><stop offset=".48" stop-color="#1b1b1b"/><stop offset="1" stop-color="#050505"/></linearGradient></defs><rect width="900" height="320" rx="28" fill="url(#g)"/><path d="M0 35 C190 90 260 10 450 60 C650 110 730 28 900 80" fill="none" stroke="#bdbdbd" stroke-width="18" opacity=".55"/><text x="450" y="118" text-anchor="middle" font-family="Arial" font-size="34" font-weight="700" fill="#fff">OMTOGEL</text><text x="450" y="178" text-anchor="middle" font-family="Arial" font-size="54" font-weight="900" fill="#e8e8e8">PROMO BANNER</text><text x="450" y="230" text-anchor="middle" font-family="Arial" font-size="22" font-weight="700" fill="#cfcfcf">atur gambar slider dari admin</text></svg>`);
%>
<div id="loader" class="loader-screen"><div class="loader-box"><% if(settings?.loaderLogoUrl || settings?.logoUrl){ %><img src="<%= settings.loaderLogoUrl || settings.logoUrl %>" alt="Loader" onerror="this.style.display='none'"><% } else { %><strong><%= settings?.siteName || 'OMTOGEL' %></strong><% } %><div class="loader-ring"></div><p><%= settings?.loaderText || 'MEMUAT APLIKASI...' %></p></div></div>
<div class="app-home" style="--bg-main:url('<%= settings?.backgroundMain || '' %>');--bg-navbar:url('<%= settings?.backgroundNavbar || '' %>')">
<header class="app-logo-head"><% if(settings?.logoUrl){ %><img src="<%= settings.logoUrl %>" alt="<%= settings?.siteName || 'OMTOGEL' %>" onerror="this.style.display='none'"><% } else { %><h1><%= settings?.siteName || 'OMTOGEL' %></h1><% } %></header>
<main class="mobile-shell">
<section class="promo-slider"><div class="slider-window"><div class="slides-track" id="slidesTrack"><% (slides.length ? slides : [{ imageUrl: fallbackBanner, link: '#' }]).forEach((slide)=>{ %><a class="slide-item" href="<%= slide.link || '#' %>"><img src="<%= slide.imageUrl || fallbackBanner %>" alt="<%= slide.title || 'Banner' %>" loading="lazy" onerror="this.src='<%= fallbackBanner %>'"></a><% }) %></div></div></section>
<section class="main-buttons"><% buttons.forEach((btn)=>{ %><a class="app-btn <%= btn.color === 'red' ? 'btn-red' : 'btn-silver' %>" href="<%= btn.link || '#' %>"><% if(btn.icon){ %><i class="<%= btn.icon %>"></i><% } %><span><%= btn.title || 'MENU' %></span></a><% }) %></section>
<% if(featureCards.length){ %><section class="feature-section"><% featureCards.forEach((card)=>{ %><a href="<%= card.link || '#' %>" class="feature-card"><% if(card.image){ %><img src="<%= card.image %>" alt="<%= card.title || 'Info' %>" loading="lazy"><% } %><span><%= card.title || 'INFO' %></span></a><% }) %></section><% } %>
</main>
<footer class="app-footer"><%= settings?.footerText || '' %></footer>
<nav class="fixed-bottom-nav"><% navs.forEach((nav)=>{ %><a href="<%= nav.link || '#' %>" class="nav-entry" style="--active-color:<%= nav.colorActive || '#b31116' %>"><i class="<%= nav.icon || 'fa-solid fa-circle' %>"></i><span><%= nav.title || 'MENU' %></span></a><% }) %></nav>
</div>
<% if(settings?.popupActive && settings?.popupImageUrl){ %><div class="welcome-popup" id="welcomePopup"><a href="<%= settings.popupLink || '#' %>"><img src="<%= settings.popupImageUrl %>" alt="Popup"></a><button type="button" id="closePopup">×</button></div><% } %>
<script>
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader')?.classList.add('hide'),500));
(()=>{const track=document.getElementById('slidesTrack');if(!track)return;const items=track.querySelectorAll('.slide-item');if(items.length<=1)return;let index=0;setInterval(()=>{index=(index+1)%items.length;track.style.transform=`translateX(-${index*100}%)`;},3200);})();
(()=>{const popup=document.getElementById('welcomePopup');if(!popup)return;setTimeout(()=>popup.classList.add('show'),Number('<%= settings?.popupTimer || 1200 %>'));document.getElementById('closePopup')?.addEventListener('click',()=>popup.remove());})();
</script>
