<div id="loader">

  <div class="loader-box">

    <% if(settings.logoUrl){ %>

      <img
        src="<%= settings.logoUrl %>"
        class="loader-logo"
        onerror="this.style.display='none'"
      >

    <% } %>

    <div class="loader-ring"></div>

    <p>
      MEMUAT APLIKASI...
    </p>

  </div>

</div>



<div
  class="sports-app"
  style="
    background-image:
      linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.96)),
      url('<%= settings.backgroundUrl || '' %>');
  "
>

  <!-- HEADER -->

  <header class="app-header">

    <a
      href="/inbox"
      class="header-box"
    >

      ✉

      <% const unreadCount =
        messages.filter(m=>!m.read).length;
      %>

      <% if(unreadCount){ %>

        <span>
          <%= unreadCount %>
        </span>

      <% } %>

    </a>

    <div class="header-logo">

      <% if(settings.logoUrl){ %>

        <img
          src="<%= settings.logoUrl %>"
          alt="<%= settings.siteName %>"
          onerror="this.style.display='none'"
        >

      <% } else { %>

        <h1>
          <%= settings.siteName || 'OMTOGEL' %>
        </h1>

      <% } %>

    </div>

    <a
      href="/livechat"
      class="header-box"
    >
      ◉
    </a>

  </header>



  <!-- SLIDER -->

  <section class="top-slider">

    <% if(sliders.length){ %>

      <div class="slider-wrap">

        <% sliders.forEach(item=>{ %>

          <a
            href="<%= item.link || '#' %>"
            class="slider-card"
          >

            <img
              src="<%= item.imageUrl || item.image %>"
              alt="<%= item.title || 'Banner' %>"
              onerror="
                this.closest('.slider-card').style.display='none'
              "
            >

          </a>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-banner">

        PREMIUM SPORTSBOOK

      </div>

    <% } %>

  </section>



  <!-- LOGIN DAFTAR -->

  <section class="auth-menu">

    <a
      href="/login"
      class="auth-card silver-card"
    >

      <div class="auth-icon">
        ◎
      </div>

      <div class="auth-text">

        <strong>
          LOGIN
        </strong>

        <small>
          AKSES MEMBER
        </small>

      </div>

    </a>

    <a
      href="/daftar"
      class="auth-card gold-card"
    >

      <div class="auth-icon">
        ✚
      </div>

      <div class="auth-text">

        <strong>
          DAFTAR
        </strong>

        <small>
          BUAT AKUN BARU
        </small>

      </div>

    </a>

  </section>



  <!-- MENU -->

  <section class="main-menu">

    <div class="main-grid">

      <% menus.forEach(menu=>{ %>

        <% if(
          menu.title !== 'LOGIN' &&
          menu.title !== 'DAFTAR'
        ){ %>

          <a
            href="<%= menu.url || '#' %>"
            class="main-card"
          >

            <div class="main-icon">

              <%= menu.icon || '✦' %>

            </div>

            <div class="main-info">

              <strong>
                <%= menu.title %>
              </strong>

              <small>
                <%= menu.subtitle || 'AKSES CEPAT' %>
              </small>

            </div>

          </a>

        <% } %>

      <% }) %>

    </div>

  </section>



  <!-- MESSAGE -->

  <section class="mini-message">

    <div class="mini-head">

      <h3>
        PESAN TERBARU
      </h3>

      <a href="/inbox">
        LIHAT
      </a>

    </div>

    <% const latestMessages =
      messages.slice(0,2);
    %>

    <% if(latestMessages.length){ %>

      <% latestMessages.forEach(msg=>{ %>

        <a
          href="/inbox"
          class="mini-card"
        >

          <small>
            <%= msg.category || 'INFO' %>
          </small>

          <strong>
            <%= msg.title %>
          </strong>

        </a>

      <% }) %>

    <% } else { %>

      <div class="mini-empty">

        BELUM ADA PESAN

      </div>

    <% } %>

  </section>



  <!-- FOOTER -->

  <footer class="app-footer">

    <p>

      <%= settings.footer || '© OMTOGEL OFFICIAL ALL RIGHTS RESERVED' %>

    </p>

  </footer>



  <!-- BOTTOM NAV -->

  <nav class="mobile-nav">

    <a href="/" class="active">

      <i>⌂</i>

      <span>HOME</span>

    </a>

    <a href="/daftar">

      <i>◎</i>

      <span>DAFTAR</span>

    </a>

    <a href="/whatsapp">

      <i>◉</i>

      <span>WHATSAPP</span>

    </a>

    <a href="/livechat">

      <i>✦</i>

      <span>LIVECHAT</span>

    </a>

  </nav>

</div>



<script>

window.addEventListener(
  'load',
  () => {

    const loader =
      document.getElementById(
        'loader'
      );

    if(loader){

      setTimeout(() => {

        loader.style.opacity = '0';

        loader.style.visibility =
          'hidden';

      }, 700);

    }

  }
);

</script>
