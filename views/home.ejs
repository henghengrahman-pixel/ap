<div id="loader">

  <div class="loader-box">

    <% if(settings.logoUrl){ %>

      <img
        src="<%= settings.logoUrl %>"
        class="loader-logo"
        alt="logo"
      >

    <% } %>

    <div class="loader-ring"></div>

    <div class="loader-info">

      <strong>
        <%= settings.siteName || 'OMTOGEL' %>
      </strong>

      <span>
        MEMUAT APLIKASI...
      </span>

    </div>

  </div>

</div>



<div
  class="sportsbook-app"
  style="
    background-image:
      linear-gradient(rgba(0,0,0,.88),rgba(0,0,0,.96)),
      url('<%= settings.backgroundUrl || '' %>');
  "
>

  <!-- HEADER -->

  <header class="sportsbook-header">

    <div class="header-logo">

      <% if(settings.logoUrl){ %>

        <img
          src="<%= settings.logoUrl %>"
          alt="logo"
        >

      <% } else { %>

        <h1>
          <%= settings.siteName || 'OMTOGEL' %>
        </h1>

      <% } %>

    </div>

    <a
      href="/inbox"
      class="header-inbox"
    >

      ✉

      <% const unreadCount = messages.filter(m=>!m.read).length; %>

      <% if(unreadCount){ %>

        <span>
          <%= unreadCount %>
        </span>

      <% } %>

    </a>

  </header>



  <!-- TICKER -->

  <div class="ticker-bar">

    <div class="ticker-badge">
      LIVE
    </div>

    <marquee>

      <%= settings.ticker || 'SELAMAT DATANG DI OMTOGEL PREMIUM SPORTSBOOK • LIVECHAT ONLINE 24 JAM • BONUS MEMBER TERSEDIA' %>

    </marquee>

  </div>



  <!-- POPUP -->

  <% if(popup && popup.image){ %>

    <div
      class="popup-overlay"
      id="promoPopup"
    >

      <div class="popup-card">

        <button
          class="popup-close"
          onclick="closePopup()"
        >
          ×
        </button>

        <a
          href="<%= popup.link || '#' %>"
          class="popup-image-wrap"
        >

          <img
            src="<%= popup.image %>"
            class="popup-image"
          >

        </a>

        <div class="popup-body">

          <h2>
            <%= popup.title || 'PROMO MEMBER' %>
          </h2>

          <p>
            <%= popup.description || '' %>
          </p>

        </div>

      </div>

    </div>

  <% } %>



  <!-- SLIDER -->

  <section class="banner-section">

    <% if(sliders.length > 0){ %>

      <div class="banner-slider">

        <% sliders.forEach(item=>{ %>

          <a
            href="<%= item.link || '#' %>"
            class="banner-card"
          >

            <img
              src="<%= item.image %>"
              alt="<%= item.title %>"
            >

          </a>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-banner">

        PREMIUM SPORTSBOOK

      </div>

    <% } %>

  </section>



  <!-- LOGIN DAFTAR -->

  <section class="auth-section">

    <div class="auth-grid">

      <a
        href="/login"
        class="auth-btn silver-auth"
      >
        LOGIN
      </a>

      <a
        href="/daftar"
        class="auth-btn red-auth"
      >
        DAFTAR
      </a>

    </div>

  </section>



  <!-- MENU -->

  <section class="sportsbook-menu">

    <div class="sportsbook-grid">

      <% menus.forEach((menu,index)=>{ %>

        <% if(
          menu.title !== 'LOGIN' &&
          menu.title !== 'DAFTAR'
        ){ %>

          <a
            href="<%= menu.url %>"
            class="
              sportsbook-card
              <%= index === 2 ? 'main-card' : '' %>
            "
          >

            <% if(menu.icon){ %>

              <div class="sportsbook-icon">

                <%= menu.icon %>

              </div>

            <% } %>

            <span>

              <%= menu.title %>

            </span>

          </a>

        <% } %>

      <% }) %>

    </div>

  </section>



  <!-- FOOTER -->

  <footer class="sportsbook-footer">

    <p>

      <%= settings.footer || '© OMTOGEL OFFICIAL ALL RIGHTS RESERVED' %>

    </p>

  </footer>



  <!-- BOTTOM NAV -->

  <nav class="dock-nav">

    <a href="/" class="active">

      <i>⌂</i>

      <span>HOME</span>

    </a>

    <a href="/daftar">

      <i>◎</i>

      <span>DAFTAR</span>

    </a>

    <a href="/whatsapp">

      <i>◉</i>

      <span>WHATSAPP</span>

    </a>

    <a href="/livechat">

      <i>✦</i>

      <span>LIVECHAT</span>

    </a>

  </nav>

</div>



<script>

window.addEventListener(
  'load',
  () => {

    const loader =
      document.getElementById(
        'loader'
      );

    setTimeout(() => {

      loader.classList.add(
        'hide'
      );

    }, 1000);

  }
);

function closePopup(){

  const popup =
    document.getElementById(
      'promoPopup'
    );

  if(popup){

    popup.style.opacity = '0';

    setTimeout(() => {

      popup.remove();

    }, 250);

  }

}

</script>
