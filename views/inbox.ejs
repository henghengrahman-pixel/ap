<section class="inbox-page"><header class="inbox-head"><h1>INBOX</h1><p>Pesan terbaru dari admin.</p></header><div class="inbox-list"><% if(messages.length){ messages.forEach(msg=>{ %><article class="inbox-card"><small><%= msg.category || 'INFO' %> • <%= msg.createdAt ? new Date(msg.createdAt).toLocaleString('id-ID') : '' %></small><h3><%= msg.title || 'Pesan' %></h3><% if(msg.imageUrl){ %><img src="<%= msg.imageUrl %>" alt="<%= msg.title || 'Pesan' %>" onerror="this.style.display='none'"><% } %><p><%= msg.message || '' %></p><% if(msg.link && msg.link !== '#'){ %><a href="<%= msg.link %>">Buka Link</a><% } %></article><% }) } else { %><article class="inbox-card"><h3>Belum ada pesan.</h3><p>Pesan dari admin akan tampil di sini.</p></article><% } %></div></section>
