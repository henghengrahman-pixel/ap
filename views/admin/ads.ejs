<h1>Iklan</h1><% if(saved){ %><div class="admin-alert">Berhasil disimpan.</div><% } %><form class="admin-card" method="post" action="/itsiregar8008/ads/save"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2>Tambah Iklan URL</h2><div class="admin-grid"><label>Title<input name="title" required></label><label>Image URL<input name="imageUrl" required></label><label>Link<input name="link" value="#"></label><label>Position<input name="position" value="home"></label><label class="check"><input type="checkbox" name="active" checked> Aktif</label></div><button class="save-btn">SIMPAN IKLAN</button></form><section class="admin-card"><% ads.forEach(a=>{ %><div class="ad-row"><% if(a.imageUrl){ %><img src="<%= a.imageUrl %>" onerror="this.style.display='none'"><% } %><b><%= a.title %></b><span><%= a.position %></span><form method="post" action="/itsiregar8008/ads/<%= a.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button>Hapus</button></form></div><% }) %></section>
