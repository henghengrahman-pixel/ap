<!doctype html><html lang="id"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Login Admin</title><link rel="stylesheet" href="/assets/css/style.css"></head><body class="login-body"><form class="login-card" method="post" action="/itsiregar8008/login"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h1>Admin Login</h1><p>Masuk untuk mengatur webview, berita, slider, menu, dan iklan.</p><% if(error){ %><div class="admin-alert error"><%= error %></div><% } %><label>Admin ID<input name="username" required autocomplete="username"></label><label>Password<input type="password" name="password" required autocomplete="current-password"></label><button>LOGIN</button></form></body></html>
