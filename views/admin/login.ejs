<!DOCTYPE html><html lang="id"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Login Admin</title><link rel="stylesheet" href="/assets/css/style.css"></head><body class="login-page" style="<%= settings?.backgroundLogin ? `background-image:linear-gradient(rgba(0,0,0,.72),rgba(0,0,0,.9)),url('${settings.backgroundLogin}')` : '' %>"><form class="login-box" action="/PINKTIGER8008/login" method="POST"><h1><%= settings?.siteName || 'OMTOGEL' %> ADMIN</h1><p>Mobile Webview Control</p><input name="username" placeholder="ADMIN ID" autocomplete="username" required><input name="password" type="password" placeholder="PASSWORD" autocomplete="current-password" required><button>LOGIN</button><% if(error){ %><div class="login-error"><%= error %></div><% } %></form></body></html>
