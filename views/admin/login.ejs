<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta
  name="viewport"
  content="
    width=device-width,
    initial-scale=1,
    maximum-scale=1,
    user-scalable=no
  "
>

<title>
  Login Admin
</title>

<link
  rel="stylesheet"
  href="/assets/css/style.css?v=11"
/>

<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
/>

</head>

<body

  class="login-page"

  style="
    background-image:
    linear-gradient(
      rgba(0,0,0,.82),
      rgba(0,0,0,.94)
    )

    <% if(settings?.backgroundLogin){ %>,

    url('<%= settings.backgroundLogin %>')

    <% } %>;
  "
>

<div class="login-overlay"></div>

<form
  class="login-box"
  action="/PINKTIGER8008/login"
  method="POST"
>

  <div class="login-logo">

    <% if(settings?.logoUrl){ %>

      <img
        src="<%= settings.logoUrl %>"
        alt="Logo"
        onerror="this.style.display='none'"
      >

    <% } else { %>

      <h1>
        OMTOGEL
      </h1>

    <% } %>

  </div>

  <div class="login-head">

    <h2>
      ADMIN PANEL
    </h2>

    <p>
      Mobile Webview Control
    </p>

  </div>

  <% if(error){ %>

    <div class="login-error">

      <i class="fa-solid fa-circle-exclamation"></i>

      <span>
        <%= error %>
      </span>

    </div>

  <% } %>

  <div class="login-form">

    <label>

      <span>
        ADMIN ID
      </span>

      <div class="login-input">

        <i class="fa-solid fa-user"></i>

        <input
          type="text"
          name="username"
          autocomplete="username"
          placeholder="Masukkan ID admin"
          required
        >

      </div>

    </label>

    <label>

      <span>
        PASSWORD
      </span>

      <div class="login-input">

        <i class="fa-solid fa-lock"></i>

        <input
          type="password"
          name="password"
          autocomplete="current-password"
          placeholder="Masukkan password"
          required
        >

      </div>

    </label>

  </div>

  <button
    type="submit"
    class="login-btn"
  >

    <i class="fa-solid fa-right-to-bracket"></i>

    LOGIN ADMIN

  </button>

</form>

</body>
</html>
