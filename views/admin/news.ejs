<h1>Berita Bola</h1><a class="save-btn" href="/itsiregar8008/news/new">Tambah Berita</a><% if(saved){ %><div class="admin-alert">Berhasil disimpan.</div><% } %><section class="admin-card"><table class="admin-table"><thead><tr><th>Judul</th><th>Kategori</th><th>Status</th><th>Aksi</th></tr></thead><tbody><% news.forEach(n=>{ %><tr><td><b><%= n.title %></b><br><small>/berita/<%= n.slug %></small></td><td><%= n.category %></td><td><%= n.active!==false?'Aktif':'Draft' %></td><td><a href="/itsiregar8008/news/<%= n.id %>/edit">Edit</a><form method="post" action="/itsiregar8008/news/<%= n.id %>/delete" onsubmit="return confirm('Hapus berita ini?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button>Hapus</button></form></td></tr><% }) %></tbody></table></section>
