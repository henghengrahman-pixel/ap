<% const a=article||{}; %><h1><%= article?'Edit':'Tambah' %> Berita</h1><form class="admin-card" method="post" action="/itsiregar8008/news/save"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="id" value="<%= a.id || '' %>"><div class="admin-grid"><label>Judul<input name="title" value="<%= a.title || '' %>" required></label><label>Slug<input name="slug" value="<%= a.slug || '' %>" placeholder="otomatis jika kosong"></label><label>Kategori<input name="category" value="<%= a.category || 'Berita Bola' %>"></label><label>Author<input name="author" value="<%= a.author || 'Redaksi Bola' %>"></label><label>Thumbnail URL<input name="thumbnailUrl" value="<%= a.thumbnailUrl || '' %>"></label><label>Cover URL<input name="coverUrl" value="<%= a.coverUrl || '' %>"></label><label>Published At<input type="datetime-local" name="publishedAt" value="<%= a.publishedAt || new Date().toISOString().slice(0,16) %>"></label><label class="check"><input type="checkbox" name="active" <%= a.active!==false?'checked':'' %>> Aktif</label></div><label>Excerpt<textarea name="excerpt"><%= a.excerpt || '' %></textarea></label><label>Isi Artikel / Blogger Editor<textarea class="article-editor" name="content"><%- a.content || '' %></textarea></label><button class="save-btn">SIMPAN BERITA</button></form>
