<% layout('layouts/main-admin') %>

<section class="admin-hero">

  <div>

    <span>
      ADMIN URL :
      /PINKTIGER8008
    </span>

    <h2>
      Setting Aplikasi Mobile
    </h2>

    <p>
      Semua logo, background,
      slider, tombol utama,
      popup, footer, dan
      bottom navbar diatur
      dari sini memakai URL/link.
    </p>

  </div>

  <b>
    <%= messages.length %> Pesan
  </b>

</section>

<form
  action="/PINKTIGER8008/settings"
  method="POST"
  class="admin-card"
>

  <h2>
    General
  </h2>

  <div class="admin-grid">

    <label>
      Nama Website

      <input
        type="text"
        name="siteName"
        value="<%= settings.siteName || '' %>"
      >

    </label>

    <label>
      Subtitle

      <input
        type="text"
        name="subtitle"
        value="<%= settings.subtitle || '' %>"
      >

    </label>

    <label>
      Logo URL

      <input
        type="text"
        name="logoUrl"
        value="<%= settings.logoUrl || '' %>"
      >

    </label>

    <label>
      Favicon URL

      <input
        type="text"
        name="faviconUrl"
        value="<%= settings.faviconUrl || '' %>"
      >

    </label>

    <label>
      Loader Logo URL

      <input
        type="text"
        name="loaderLogoUrl"
        value="<%= settings.loaderLogoUrl || '' %>"
      >

    </label>

    <label>
      Loader Text

      <input
        type="text"
        name="loaderText"
        value="<%= settings.loaderText || '' %>"
      >

    </label>

    <label class="full">

      Footer Text

      <input
        type="text"
        name="footerText"
        value="<%= settings.footerText || '' %>"
      >

    </label>

    <label class="full">

      Meta Description

      <textarea
        name="siteDescription"
      ><%= settings.siteDescription || '' %></textarea>

    </label>

    <label class="full">

      Meta Keywords

      <textarea
        name="siteKeywords"
      ><%= settings.siteKeywords || '' %></textarea>

    </label>

  </div>

  <h2>
    Background URL
  </h2>

  <div class="admin-grid">

    <label>
      Background Utama

      <input
        type="text"
        name="backgroundMain"
        value="<%= settings.backgroundMain || '' %>"
      >

    </label>

    <label>
      Background Mobile

      <input
        type="text"
        name="backgroundMobile"
        value="<%= settings.backgroundMobile || '' %>"
      >

    </label>

    <label>
      Background Desktop

      <input
        type="text"
        name="backgroundDesktop"
        value="<%= settings.backgroundDesktop || '' %>"
      >

    </label>

    <label>
      Background Login

      <input
        type="text"
        name="backgroundLogin"
        value="<%= settings.backgroundLogin || '' %>"
      >

    </label>

    <label>
      Background Popup

      <input
        type="text"
        name="backgroundPopup"
        value="<%= settings.backgroundPopup || '' %>"
      >

    </label>

    <label>
      Background Footer

      <input
        type="text"
        name="backgroundFooter"
        value="<%= settings.backgroundFooter || '' %>"
      >

    </label>

    <label>
      Background Navbar

      <input
        type="text"
        name="backgroundNavbar"
        value="<%= settings.backgroundNavbar || '' %>"
      >

    </label>

    <label>
      Background Loading

      <input
        type="text"
        name="backgroundLoading"
        value="<%= settings.backgroundLoading || '' %>"
      >

    </label>

  </div>

  <h2>
    Slider Promo
  </h2>

  <div class="admin-repeat">

    <% for(let i = 0; i < 12; i++){ %>

      <% const slide = (settings.sliders || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Slide <%= n %>
        </h3>

        <input
          type="hidden"
          name="slide<%= n %>Id"
          value="<%= slide.id || '' %>"
        >

        <label>

          Judul

          <input
            type="text"
            name="slide<%= n %>Title"
            value="<%= slide.title || '' %>"
          >

        </label>

        <label>

          Gambar URL

          <input
            type="text"
            name="slide<%= n %>ImageUrl"
            value="<%= slide.imageUrl || '' %>"
          >

        </label>

        <label>

          Link

          <input
            type="text"
            name="slide<%= n %>Link"
            value="<%= slide.link || '' %>"
          >

        </label>

        <label>

          Urutan

          <input
            type="number"
            name="slide<%= n %>Order"
            value="<%= slide.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="slide<%= n %>Active"
            <%= slide.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <h2>
    Tombol Utama
  </h2>

  <div class="admin-repeat">

    <% for(let i = 0; i < 14; i++){ %>

      <% const btn = (settings.buttons || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Tombol <%= n %>
        </h3>

        <input
          type="hidden"
          name="button<%= n %>Id"
          value="<%= btn.id || '' %>"
        >

        <label>

          Nama Tombol

          <input
            type="text"
            name="button<%= n %>Title"
            value="<%= btn.title || '' %>"
          >

        </label>

        <label>

          Link

          <input
            type="text"
            name="button<%= n %>Link"
            value="<%= btn.link || '' %>"
          >

        </label>

        <label>

          Icon

          <input
            type="text"
            name="button<%= n %>Icon"
            value="<%= btn.icon || '' %>"
            placeholder="fa-solid fa-star"
          >

        </label>

        <label>

          Warna

          <select
            name="button<%= n %>Color"
          >

            <option
              value="silver"
              <%= btn.color !== 'red'
              ? 'selected'
              : '' %>
            >
              Silver Chrome
            </option>

            <option
              value="red"
              <%= btn.color === 'red'
              ? 'selected'
              : '' %>
            >
              Merah Daftar
            </option>

          </select>

        </label>

        <label>

          Urutan

          <input
            type="number"
            name="button<%= n %>Order"
            value="<%= btn.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="button<%= n %>Active"
            <%= btn.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <h2>
    Bottom Navbar
  </h2>

  <div class="admin-repeat">

    <% for(let i = 0; i < 8; i++){ %>

      <% const nav = (settings.bottomNav || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Navbar <%= n %>
        </h3>

        <input
          type="hidden"
          name="nav<%= n %>Id"
          value="<%= nav.id || '' %>"
        >

        <label>

          Text

          <input
            type="text"
            name="nav<%= n %>Title"
            value="<%= nav.title || '' %>"
          >

        </label>

        <label>

          Icon

          <input
            type="text"
            name="nav<%= n %>Icon"
            value="<%= nav.icon || '' %>"
          >

        </label>

        <label>

          Link

          <input
            type="text"
            name="nav<%= n %>Link"
            value="<%= nav.link || '' %>"
          >

        </label>

        <label>

          Warna Active

          <input
            type="text"
            name="nav<%= n %>ColorActive"
            value="<%= nav.colorActive || '#d21717' %>"
          >

        </label>

        <label>

          Urutan

          <input
            type="number"
            name="nav<%= n %>Order"
            value="<%= nav.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="nav<%= n %>Active"
            <%= nav.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <h2>
    Popup
  </h2>

  <div class="admin-grid">

    <label>

      Gambar Popup URL

      <input
        type="text"
        name="popupImageUrl"
        value="<%= settings.popupImageUrl || '' %>"
      >

    </label>

    <label>

      Link Popup

      <input
        type="text"
        name="popupLink"
        value="<%= settings.popupLink || '' %>"
      >

    </label>

    <label>

      Timer Popup

      <input
        type="number"
        name="popupTimer"
        value="<%= settings.popupTimer || 1200 %>"
      >

    </label>

    <label class="check">

      <input
        type="checkbox"
        name="popupActive"
        <%= settings.popupActive ? 'checked' : '' %>
      >

      Popup Aktif

    </label>

  </div>

  <button class="save-btn">

    <i class="fa-solid fa-floppy-disk"></i>

    Simpan Semua Setting

  </button>

</form>

<section
  class="admin-card"
  id="messages"
>

  <h2>
    Inbox Pesan
  </h2>

  <form
    action="/PINKTIGER8008/message/add"
    method="POST"
    class="admin-grid"
  >

    <label>

      Kategori

      <input
        type="text"
        name="category"
      >

    </label>

    <label>

      Judul

      <input
        type="text"
        name="title"
        required
      >

    </label>

    <label>

      Image URL

      <input
        type="text"
        name="imageUrl"
      >

    </label>

    <label>

      Link

      <input
        type="text"
        name="link"
      >

    </label>

    <label class="full">

      Pesan

      <textarea
        name="message"
        required
      ></textarea>

    </label>

    <button class="save-btn">

      Kirim Pesan

    </button>

  </form>

</section>
