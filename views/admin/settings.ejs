<h1>Pengaturan Website</h1><% if(saved){ %><div class="admin-alert">Berhasil disimpan.</div><% } %><% if(error){ %><div class="admin-alert error"><%= error %></div><% } %><form class="admin-card" method="post" action="/itsiregar8008/settings"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><h2>Brand & SEO</h2><div class="admin-grid"><label>Nama Website<input name="siteName" value="<%= settings.siteName %>" required></label><label>Subtitle<input name="siteSubtitle" value="<%= settings.siteSubtitle || '' %>"></label><label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl || '' %>" placeholder="https://..."></label><label>Favicon URL<input name="faviconUrl" value="<%= settings.faviconUrl || '' %>"></label><label>Background Desktop URL<input name="backgroundUrl" value="<%= settings.backgroundUrl || '' %>"></label><label>Background Mobile URL<input name="backgroundMobileUrl" value="<%= settings.backgroundMobileUrl || '' %>"></label><label>Theme Color<input name="themeColor" value="<%= settings.themeColor %>"></label><label>Silver Accent<input name="accentColor" value="<%= settings.accentColor %>"></label><label>Gold Accent<input name="goldColor" value="<%= settings.goldColor %>"></label><label>Main Webview URL<input name="mainWebviewUrl" value="<%= settings.mainWebviewUrl || '/' %>"></label><label>Login URL<input name="loginUrl" value="<%= settings.loginUrl || '' %>"></label><label>Daftar URL<input name="registerUrl" value="<%= settings.registerUrl || '' %>"></label><label>Livescore URL<input name="livescoreUrl" value="<%= settings.livescoreUrl || '/livescore' %>"></label><label>Berita URL<input name="newsUrl" value="<%= settings.newsUrl || '/berita' %>"></label><label>WhatsApp URL<input name="whatsappUrl" value="<%= settings.whatsappUrl || '' %>"></label><label>LiveChat URL<input name="liveChatUrl" value="<%= settings.liveChatUrl || '' %>"></label></div><label>Meta Description<textarea name="siteDescription"><%= settings.siteDescription || '' %></textarea></label><label>Meta Keywords<textarea name="siteKeywords"><%= settings.siteKeywords || '' %></textarea></label><label>Ticker Text<textarea name="tickerText"><%= settings.tickerText || '' %></textarea></label><label>Footer Text<input name="footerText" value="<%= settings.footerText || '' %>"></label><h2>Slider URL</h2><div class="admin-grid"><% for(let i=0;i<6;i++){ const s=(settings.sliders||[])[i]||{}; const n=i+1; %><div class="mini-card"><b>Slide <%= n %></b><label>Judul<input name="slide<%= n %>Title" value="<%= s.title || '' %>"></label><label>Image URL<input name="slide<%= n %>ImageUrl" value="<%= s.imageUrl || '' %>"></label><label>Link<input name="slide<%= n %>Link" value="<%= s.link || '#' %>"></label><label class="check"><input type="checkbox" name="slide<%= n %>Active" <%= s.active!==false?'checked':'' %>> Aktif</label></div><% } %></div><h2>Quick Menu URL</h2><div class="admin-grid"><% for(let i=0;i<8;i++){ const m=(settings.quickMenus||[])[i]||{}; const n=i+1; %><div class="mini-card"><b>Menu <%= n %></b><label>Judul<input name="menu<%= n %>Title" value="<%= m.title || '' %>"></label><label>Image URL<input name="menu<%= n %>ImageUrl" value="<%= m.imageUrl || '' %>"></label><label>Link<input name="menu<%= n %>Link" value="<%= m.link || '#' %>"></label><label class="check"><input type="checkbox" name="menu<%= n %>Active" <%= m.active!==false?'checked':'' %>> Aktif</label><label class="check"><input type="checkbox" name="menu<%= n %>Featured" <%= m.featured?'checked':'' %>> Featured</label></div><% } %></div><button class="save-btn">SIMPAN SEMUA SETTINGS</button></form><section id="messages" class="admin-card"><h2>Broadcast / Inbox</h2><form method="post" action="/itsiregar8008/message/add"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="admin-grid"><label>Judul<input name="title"></label><label>Kategori<input name="category" value="INFO"></label><label>Image URL<input name="imageUrl"></label><label>Link<input name="link"></label></div><label>Pesan<textarea name="message"></textarea></label><button class="save-btn">Kirim Pesan</button></form></section>
