<section class="admin-hero">

  <div>

    <span class="hero-badge">
      ADMIN URL :
      /PINKTIGER8008
    </span>

    <h2>
      Setting Aplikasi Mobile
    </h2>

    <p>
      Semua logo, background,
      slider, tombol utama,
      feature card, popup,
      footer, dan bottom navbar
      diatur dari panel ini.
    </p>

  </div>

  <b class="hero-counter">
    <%= messages.length %> Pesan
  </b>

</section>

<form
  action="/PINKTIGER8008/settings"
  method="POST"
  class="admin-card"
>

  <!-- ===================== -->
  <!-- GENERAL -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      General Setting
    </h2>

  </div>

  <div class="admin-grid">

    <label>

      <span>
        Nama Website
      </span>

      <input
        type="text"
        name="siteName"
        value="<%= settings.siteName || '' %>"
      >

    </label>

    <label>

      <span>
        Subtitle
      </span>

      <input
        type="text"
        name="subtitle"
        value="<%= settings.subtitle || '' %>"
      >

    </label>

    <label>

      <span>
        Logo URL
      </span>

      <input
        type="text"
        name="logoUrl"
        value="<%= settings.logoUrl || '' %>"
      >

    </label>

    <label>

      <span>
        Favicon URL
      </span>

      <input
        type="text"
        name="faviconUrl"
        value="<%= settings.faviconUrl || '' %>"
      >

    </label>

    <label>

      <span>
        Loader Logo URL
      </span>

      <input
        type="text"
        name="loaderLogoUrl"
        value="<%= settings.loaderLogoUrl || '' %>"
      >

    </label>

    <label>

      <span>
        Loader Text
      </span>

      <input
        type="text"
        name="loaderText"
        value="<%= settings.loaderText || '' %>"
      >

    </label>

    <label class="full">

      <span>
        Footer Text
      </span>

      <input
        type="text"
        name="footerText"
        value="<%= settings.footerText || '' %>"
      >

    </label>

    <label class="full">

      <span>
        Meta Description
      </span>

      <textarea
        name="siteDescription"
      ><%= settings.siteDescription || '' %></textarea>

    </label>

    <label class="full">

      <span>
        Meta Keywords
      </span>

      <textarea
        name="siteKeywords"
      ><%= settings.siteKeywords || '' %></textarea>

    </label>

  </div>

  <!-- ===================== -->
  <!-- BACKGROUND -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Background Mobile
    </h2>

  </div>

  <div class="admin-grid">

    <label class="full">

      <span>
        Background Utama
      </span>

      <input
        type="text"
        name="backgroundMain"
        value="<%= settings.backgroundMain || '' %>"
      >

    </label>

    <label>

      <span>
        Background Login
      </span>

      <input
        type="text"
        name="backgroundLogin"
        value="<%= settings.backgroundLogin || '' %>"
      >

    </label>

    <label>

      <span>
        Background Popup
      </span>

      <input
        type="text"
        name="backgroundPopup"
        value="<%= settings.backgroundPopup || '' %>"
      >

    </label>

    <label>

      <span>
        Background Footer
      </span>

      <input
        type="text"
        name="backgroundFooter"
        value="<%= settings.backgroundFooter || '' %>"
      >

    </label>

    <label>

      <span>
        Background Navbar
      </span>

      <input
        type="text"
        name="backgroundNavbar"
        value="<%= settings.backgroundNavbar || '' %>"
      >

    </label>

    <label>

      <span>
        Background Loading
      </span>

      <input
        type="text"
        name="backgroundLoading"
        value="<%= settings.backgroundLoading || '' %>"
      >

    </label>

  </div>

  <!-- ===================== -->
  <!-- SLIDER -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Slider Promo
    </h2>

  </div>

  <div class="admin-repeat">

    <% for(let i = 0; i < 12; i++){ %>

      <% const slide = (settings.sliders || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Slide <%= n %>
        </h3>

        <input
          type="hidden"
          name="slide<%= n %>Id"
          value="<%= slide.id || '' %>"
        >

        <label>

          <span>
            Judul
          </span>

          <input
            type="text"
            name="slide<%= n %>Title"
            value="<%= slide.title || '' %>"
          >

        </label>

        <label>

          <span>
            Gambar URL
          </span>

          <input
            type="text"
            name="slide<%= n %>ImageUrl"
            value="<%= slide.imageUrl || '' %>"
          >

        </label>

        <label>

          <span>
            Link
          </span>

          <input
            type="text"
            name="slide<%= n %>Link"
            value="<%= slide.link || '' %>"
          >

        </label>

        <label>

          <span>
            Urutan
          </span>

          <input
            type="number"
            name="slide<%= n %>Order"
            value="<%= slide.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="slide<%= n %>Active"
            <%= slide.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <!-- ===================== -->
  <!-- BUTTON -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Tombol Utama
    </h2>

  </div>

  <div class="admin-repeat">

    <% for(let i = 0; i < 14; i++){ %>

      <% const btn = (settings.buttons || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Tombol <%= n %>
        </h3>

        <input
          type="hidden"
          name="button<%= n %>Id"
          value="<%= btn.id || '' %>"
        >

        <label>

          <span>
            Nama Tombol
          </span>

          <input
            type="text"
            name="button<%= n %>Title"
            value="<%= btn.title || '' %>"
          >

        </label>

        <label>

          <span>
            Link
          </span>

          <input
            type="text"
            name="button<%= n %>Link"
            value="<%= btn.link || '' %>"
          >

        </label>

        <label>

          <span>
            Icon
          </span>

          <input
            type="text"
            name="button<%= n %>Icon"
            value="<%= btn.icon || '' %>"
          >

        </label>

        <label>

          <span>
            Warna
          </span>

          <select
            name="button<%= n %>Color"
          >

            <option
              value="silver"
              <%= btn.color !== 'red'
              ? 'selected'
              : '' %>
            >
              Silver
            </option>

            <option
              value="red"
              <%= btn.color === 'red'
              ? 'selected'
              : '' %>
            >
              Red
            </option>

          </select>

        </label>

        <label>

          <span>
            Urutan
          </span>

          <input
            type="number"
            name="button<%= n %>Order"
            value="<%= btn.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="button<%= n %>Active"
            <%= btn.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <!-- ===================== -->
  <!-- FEATURE CARD -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Feature Card
    </h2>

  </div>

  <div class="admin-repeat">

    <% for(let i = 0; i < 12; i++){ %>

      <% const feature = (settings.featureCards || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Feature <%= n %>
        </h3>

        <input
          type="hidden"
          name="feature<%= n %>Id"
          value="<%= feature.id || '' %>"
        >

        <label>

          <span>
            Judul
          </span>

          <input
            type="text"
            name="feature<%= n %>Title"
            value="<%= feature.title || '' %>"
          >

        </label>

        <label>

          <span>
            Gambar URL
          </span>

          <input
            type="text"
            name="feature<%= n %>Image"
            value="<%= feature.image || '' %>"
          >

        </label>

        <label>

          <span>
            Link
          </span>

          <input
            type="text"
            name="feature<%= n %>Link"
            value="<%= feature.link || '' %>"
          >

        </label>

        <label>

          <span>
            Urutan
          </span>

          <input
            type="number"
            name="feature<%= n %>Order"
            value="<%= feature.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="feature<%= n %>Active"
            <%= feature.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <!-- ===================== -->
  <!-- BOTTOM NAV -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Bottom Navbar
    </h2>

  </div>

  <div class="admin-repeat">

    <% for(let i = 0; i < 8; i++){ %>

      <% const nav = (settings.bottomNav || [])[i] || {}; %>

      <% const n = i + 1; %>

      <section>

        <h3>
          Navbar <%= n %>
        </h3>

        <input
          type="hidden"
          name="nav<%= n %>Id"
          value="<%= nav.id || '' %>"
        >

        <label>

          <span>
            Nama
          </span>

          <input
            type="text"
            name="nav<%= n %>Title"
            value="<%= nav.title || '' %>"
          >

        </label>

        <label>

          <span>
            Icon
          </span>

          <input
            type="text"
            name="nav<%= n %>Icon"
            value="<%= nav.icon || '' %>"
          >

        </label>

        <label>

          <span>
            Link
          </span>

          <input
            type="text"
            name="nav<%= n %>Link"
            value="<%= nav.link || '' %>"
          >

        </label>

        <label>

          <span>
            Warna Active
          </span>

          <input
            type="text"
            name="nav<%= n %>ColorActive"
            value="<%= nav.colorActive || '#d21717' %>"
          >

        </label>

        <label>

          <span>
            Urutan
          </span>

          <input
            type="number"
            name="nav<%= n %>Order"
            value="<%= nav.order || n %>"
          >

        </label>

        <label class="check">

          <input
            type="checkbox"
            name="nav<%= n %>Active"
            <%= nav.active !== false ? 'checked' : '' %>
          >

          Aktif

        </label>

      </section>

    <% } %>

  </div>

  <!-- ===================== -->
  <!-- POPUP -->
  <!-- ===================== -->

  <div class="admin-section-title">

    <h2>
      Popup
    </h2>

  </div>

  <div class="admin-grid">

    <label class="full">

      <span>
        Popup Image URL
      </span>

      <input
        type="text"
        name="popupImageUrl"
        value="<%= settings.popupImageUrl || '' %>"
      >

    </label>

    <label>

      <span>
        Popup Link
      </span>

      <input
        type="text"
        name="popupLink"
        value="<%= settings.popupLink || '' %>"
      >

    </label>

    <label>

      <span>
        Popup Timer
      </span>

      <input
        type="number"
        name="popupTimer"
        value="<%= settings.popupTimer || 1200 %>"
      >

    </label>

    <label class="check">

      <input
        type="checkbox"
        name="popupActive"
        <%= settings.popupActive ? 'checked' : '' %>
      >

      Popup Aktif

    </label>

  </div>

  <!-- ===================== -->
  <!-- SAVE -->
  <!-- ===================== -->

  <button class="save-btn">

    <i class="fa-solid fa-floppy-disk"></i>

    Simpan Semua Setting

  </button>

</form>
