<div class="admin-wrap">
  <aside class="admin-side"><h1><i class="fa-solid fa-mobile-screen"></i> <%= settings.siteName || 'OMTOGEL' %></h1><p>Control panel aplikasi webview.</p><a href="/" target="_blank"><i class="fa-solid fa-eye"></i> Lihat Website</a><a href="/PINKTIGER8008/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a></aside>
  <main class="admin-main">
    <section class="admin-hero"><div><span>ADMIN URL: /PINKTIGER8008</span><h2>Setting Aplikasi Mobile</h2><p>Semua logo, background, slider, tombol utama, popup, footer, dan bottom navbar diatur dari sini pakai URL/link.</p></div><b><%= messages.length %> Pesan</b></section>
    <form action="/PINKTIGER8008/settings" method="POST" class="admin-card">
      <h2>General</h2><div class="admin-grid">
        <label>Nama Website<input name="siteName" value="<%= settings.siteName || '' %>"></label><label>Subtitle<input name="subtitle" value="<%= settings.subtitle || '' %>"></label>
        <label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl || '' %>"></label><label>Favicon URL<input name="faviconUrl" value="<%= settings.faviconUrl || '' %>"></label>
        <label>Loader Logo URL<input name="loaderLogoUrl" value="<%= settings.loaderLogoUrl || '' %>"></label><label>Loader Text<input name="loaderText" value="<%= settings.loaderText || '' %>"></label>
        <label class="full">Footer Text<input name="footerText" value="<%= settings.footerText || '' %>"></label>
        <label class="full">Meta Description<textarea name="siteDescription"><%= settings.siteDescription || '' %></textarea></label><label class="full">Meta Keywords<textarea name="siteKeywords"><%= settings.siteKeywords || '' %></textarea></label>
      </div>
      <h2>Background URL</h2><div class="admin-grid">
        <label>Background Utama<input name="backgroundMain" value="<%= settings.backgroundMain || '' %>"></label><label>Background Mobile<input name="backgroundMobile" value="<%= settings.backgroundMobile || '' %>"></label><label>Background Desktop<input name="backgroundDesktop" value="<%= settings.backgroundDesktop || '' %>"></label><label>Background Login<input name="backgroundLogin" value="<%= settings.backgroundLogin || '' %>"></label><label>Background Popup<input name="backgroundPopup" value="<%= settings.backgroundPopup || '' %>"></label><label>Background Footer<input name="backgroundFooter" value="<%= settings.backgroundFooter || '' %>"></label><label>Background Navbar<input name="backgroundNavbar" value="<%= settings.backgroundNavbar || '' %>"></label><label>Background Loading<input name="backgroundLoading" value="<%= settings.backgroundLoading || '' %>"></label>
      </div>
      <h2>Slider Promo</h2><div class="admin-repeat">
        <% for(let i=0;i<12;i++){ const s=(settings.sliders||[])[i]||{}; const n=i+1; %><section><h3>Slide <%= n %></h3><input type="hidden" name="slide<%= n %>Id" value="<%= s.id || '' %>"><label>Judul<input name="slide<%= n %>Title" value="<%= s.title || '' %>"></label><label>Gambar URL<input name="slide<%= n %>ImageUrl" value="<%= s.imageUrl || '' %>"></label><label>Link<input name="slide<%= n %>Link" value="<%= s.link || '' %>"></label><label>Urutan<input type="number" name="slide<%= n %>Order" value="<%= s.order || n %>"></label><label class="check"><input type="checkbox" name="slide<%= n %>Active" <%= s.active !== false ? 'checked' : '' %>> Aktif</label></section><% } %>
      </div>
      <h2>Tombol Utama</h2><div class="admin-repeat">
        <% for(let i=0;i<14;i++){ const b=(settings.buttons||[])[i]||{}; const n=i+1; %><section><h3>Tombol <%= n %></h3><input type="hidden" name="button<%= n %>Id" value="<%= b.id || '' %>"><label>Nama<input name="button<%= n %>Title" value="<%= b.title || '' %>"></label><label>Link<input name="button<%= n %>Link" value="<%= b.link || '' %>"></label><label>Icon Opsional<input name="button<%= n %>Icon" value="<%= b.icon || '' %>" placeholder="fa-solid fa-star"></label><label>Warna<select name="button<%= n %>Color"><option value="silver" <%= b.color !== 'red' ? 'selected' : '' %>>Silver Chrome</option><option value="red" <%= b.color === 'red' ? 'selected' : '' %>>Merah Daftar</option></select></label><label>Urutan<input type="number" name="button<%= n %>Order" value="<%= b.order || n %>"></label><label class="check"><input type="checkbox" name="button<%= n %>Active" <%= b.active !== false ? 'checked' : '' %>> Aktif</label></section><% } %>
      </div>
      <h2>Bottom Navbar</h2><div class="admin-repeat nav-repeat">
        <% for(let i=0;i<8;i++){ const nav=(settings.bottomNav||[])[i]||{}; const n=i+1; %><section><h3>Nav <%= n %></h3><input type="hidden" name="nav<%= n %>Id" value="<%= nav.id || '' %>"><label>Text<input name="nav<%= n %>Title" value="<%= nav.title || '' %>"></label><label>Icon<input name="nav<%= n %>Icon" value="<%= nav.icon || '' %>"></label><label>Link<input name="nav<%= n %>Link" value="<%= nav.link || '' %>"></label><label>Warna Active<input name="nav<%= n %>ColorActive" value="<%= nav.colorActive || '#d21717' %>"></label><label>Urutan<input type="number" name="nav<%= n %>Order" value="<%= nav.order || n %>"></label><label class="check"><input type="checkbox" name="nav<%= n %>Active" <%= nav.active !== false ? 'checked' : '' %>> Aktif</label></section><% } %>
      </div>
      <h2>Popup</h2><div class="admin-grid"><label>Gambar Popup URL<input name="popupImageUrl" value="<%= settings.popupImageUrl || '' %>"></label><label>Link Popup<input name="popupLink" value="<%= settings.popupLink || '' %>"></label><label>Timer Popup ms<input type="number" name="popupTimer" value="<%= settings.popupTimer || 1200 %>"></label><label class="check"><input type="checkbox" name="popupActive" <%= settings.popupActive ? 'checked' : '' %>> Popup Aktif</label></div>
      <button class="save-btn"><i class="fa-solid fa-floppy-disk"></i> Simpan Semua Setting</button>
    </form>
    <section class="admin-card" id="messages"><h2>Inbox Pesan</h2><form action="/PINKTIGER8008/message/add" method="POST" class="admin-grid"><label>Kategori<input name="category"></label><label>Judul<input name="title" required></label><label>Image URL<input name="imageUrl"></label><label>Link<input name="link"></label><label class="full">Pesan<textarea name="message" required></textarea></label><button class="save-btn">Kirim Pesan</button></form><div class="message-admin-list"><% if(messages.length){ messages.forEach(msg=>{ %><article><div><small><%= msg.category %> • <%= msg.createdAt ? new Date(msg.createdAt).toLocaleString('id-ID') : '' %></small><strong><%= msg.title %></strong><p><%= msg.message %></p></div><form action="/PINKTIGER8008/message/delete/<%= msg._id %>" method="POST"><button class="delete-btn">Hapus</button></form></article><% }) } else { %><p class="empty-box">Belum ada pesan.</p><% } %></div><form action="/PINKTIGER8008/messages/clear" method="POST"><button class="delete-btn">Hapus Semua Pesan</button></form></section>
  </main>
</div>
