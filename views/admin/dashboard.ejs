<div class="admin-wrap">

  <div class="admin-header">
    <h1>OMTOGEL ADMIN PANEL</h1>
    <p>Premium Control Center</p>
  </div>


  <!-- SETTINGS -->
  <form
    action="/itsiregar8008/settings"
    method="POST"
    enctype="multipart/form-data"
    class="admin-card"
  >

    <h2>SETTINGS WEBSITE</h2>

    <div class="admin-grid">

      <div class="form-group">
        <label>Nama Aplikasi</label>
        <input
          type="text"
          name="siteName"
          placeholder="Nama aplikasi"
          value="<%= settings.siteName || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Subtitle</label>
        <input
          type="text"
          name="subtitle"
          placeholder="Subtitle"
          value="<%= settings.subtitle || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Text Berjalan</label>
        <input
          type="text"
          name="ticker"
          placeholder="Ticker berjalan"
          value="<%= settings.ticker || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Footer</label>
        <input
          type="text"
          name="footer"
          placeholder="Footer"
          value="<%= settings.footer || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Link Login</label>
        <input
          type="text"
          name="loginUrl"
          placeholder="Login URL"
          value="<%= settings.loginUrl || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Link Daftar</label>
        <input
          type="text"
          name="registerUrl"
          placeholder="Daftar URL"
          value="<%= settings.registerUrl || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Link WhatsApp</label>
        <input
          type="text"
          name="whatsappUrl"
          placeholder="Whatsapp URL"
          value="<%= settings.whatsappUrl || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Link Livechat</label>
        <input
          type="text"
          name="livechatUrl"
          placeholder="Livechat URL"
          value="<%= settings.livechatUrl || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Logo Website</label>
        <input type="file" name="logo">
      </div>

      <div class="form-group">
        <label>Background Website</label>
        <input type="file" name="background">
      </div>

      <div class="form-group">
        <label>Favicon</label>
        <input type="file" name="favicon">
      </div>

    </div>

    <button type="submit" class="save-btn">
      SAVE SETTINGS
    </button>

  </form>



  <!-- SLIDER -->
  <form
    action="/itsiregar8008/slider/add"
    method="POST"
    enctype="multipart/form-data"
    class="admin-card"
  >

    <h2>SLIDER / BANNER</h2>

    <div class="admin-grid">

      <div class="form-group">
        <label>Judul Banner</label>
        <input
          type="text"
          name="title"
          placeholder="Judul banner"
        >
      </div>

      <div class="form-group">
        <label>Link Banner</label>
        <input
          type="text"
          name="link"
          placeholder="Link banner"
        >
      </div>

      <div class="form-group">
        <label>Upload Banner</label>
        <input type="file" name="image">
      </div>

    </div>

    <button type="submit" class="save-btn">
      TAMBAH SLIDER
    </button>

  </form>



  <!-- LIST SLIDER -->
  <div class="admin-card">

    <h2>LIST SLIDER</h2>

    <% if(sliders.length > 0){ %>

      <div class="slider-admin-list">

        <% sliders.forEach(slider => { %>

          <div class="slider-item">

            <img
              src="<%= slider.image %>"
              class="slider-thumb"
            >

            <div class="slider-content">

              <h3>
                <%= slider.title %>
              </h3>

              <p>
                <%= slider.link %>
              </p>

              <form
                action="/itsiregar8008/slider/delete/<%= slider.id %>"
                method="POST"
              >

                <button
                  type="submit"
                  class="delete-btn"
                >
                  HAPUS
                </button>

              </form>

            </div>

          </div>

        <% }) %>

      </div>

    <% } else { %>

      <div class="empty-box">
        BELUM ADA SLIDER
      </div>

    <% } %>

  </div>



  <!-- POPUP -->
  <form
    action="/itsiregar8008/popup"
    method="POST"
    enctype="multipart/form-data"
    class="admin-card"
  >

    <h2>POPUP PROMO</h2>

    <div class="admin-grid">

      <div class="form-group">
        <label>Judul Popup</label>
        <input
          type="text"
          name="title"
          placeholder="Judul popup"
          value="<%= popup.title || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Deskripsi Popup</label>
        <textarea
          name="description"
          placeholder="Isi popup"
        ><%= popup.description || '' %></textarea>
      </div>

      <div class="form-group">
        <label>Link Popup</label>
        <input
          type="text"
          name="link"
          placeholder="Link popup"
          value="<%= popup.link || '' %>"
        >
      </div>

      <div class="form-group">
        <label>Upload Popup Image</label>
        <input type="file" name="image">
      </div>

    </div>

    <button type="submit" class="save-btn">
      SAVE POPUP
    </button>

  </form>



  <!-- PUSH NOTIFICATION -->
  <form
    action="/itsiregar8008/broadcast"
    method="POST"
    class="admin-card"
  >

    <h2>PUSH NOTIFICATION</h2>

    <div class="admin-grid">

      <div class="form-group">
        <label>Judul Notifikasi</label>
        <input
          type="text"
          name="title"
          placeholder="Title"
        >
      </div>

      <div class="form-group full">
        <label>Isi Notifikasi</label>
        <textarea
          name="message"
          placeholder="Message"
        ></textarea>
      </div>

    </div>

    <button type="submit" class="save-btn">
      KIRIM NOTIFIKASI
    </button>

  </form>



  <!-- LOGOUT -->
  <a
    href="/itsiregar8008/logout"
    class="logout-btn"
  >
    LOGOUT
  </a>

</div>
