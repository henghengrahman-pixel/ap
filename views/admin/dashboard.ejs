<div class="admin-wrap">
  <aside class="admin-side">
    <h1><i class="fa-solid fa-gem"></i> OMTOGEL</h1>
    <p>Premium Mobile Webview Control</p>
    <a href="/" target="_blank"><i class="fa-solid fa-mobile-screen"></i> Lihat Website</a>
    <a href="/itsiregar8008/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
  </aside>

  <main class="admin-main">
    <section class="admin-hero">
      <div>
        <span>FINAL APP STYLE</span>
        <h2>Webview, Bottom Navbar & Popup Menu</h2>
        <p>Admin sudah difokuskan hanya untuk logo, favicon, URL webview, link bottom menu, dan 8 card popup menu.</p>
      </div>
      <div class="admin-stats"><b><%= messages.length %></b><small>Pesan Inbox</small></div>
    </section>

    <form action="/itsiregar8008/settings" method="POST" enctype="multipart/form-data" class="admin-card">
      <h2>Branding Aplikasi</h2>
      <div class="admin-grid">
        <label>Nama Aplikasi<input name="siteName" value="<%= settings.siteName || '' %>" placeholder="OMTOGEL"></label>
        <label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl || '' %>" placeholder="https://domain/logo.png"></label>
        <label>Upload Logo<input type="file" name="logoUrl" accept="image/*"></label>
        <label>Favicon URL<input name="faviconUrl" value="<%= settings.faviconUrl || '' %>" placeholder="https://domain/favicon.png"></label>
        <label>Upload Favicon<input type="file" name="faviconUrl" accept="image/*"></label>
        <label class="full">Meta Description<textarea name="siteDescription" placeholder="Deskripsi SEO singkat"><%= settings.siteDescription || '' %></textarea></label>
        <label class="full">Meta Keywords<textarea name="siteKeywords" placeholder="keyword1, keyword2"><%= settings.siteKeywords || '' %></textarea></label>
      </div>

      <h2 class="section-title">Link Webview & Bottom Navbar</h2>
      <div class="admin-grid">
        <label class="full">Webview URL Utama / Home<input name="mainWebviewUrl" value="<%= settings.mainWebviewUrl || '' %>" placeholder="https://domain-login.com atau /blank-frame"></label>
        <label>Link LIVEDRAW<input name="liveDrawUrl" value="<%= settings.liveDrawUrl || '' %>" placeholder="https://..."></label>
        <label>Link WHATSAPP<input name="whatsappUrl" value="<%= settings.whatsappUrl || '' %>" placeholder="https://wa.me/62..."></label>
        <label>Link INBOX<input name="inboxUrl" value="<%= settings.inboxUrl || '/inbox-frame' %>" placeholder="/inbox-frame"></label>
      </div>

      <h2 class="section-title">Popup Menu Card 1 - 8</h2>
      <div class="menu-admin-grid">
        <% for(let i=0;i<8;i++){ const card = settings.menuCards[i] || {}; const n = i + 1; %>
          <section class="menu-admin-card">
            <div class="menu-admin-title">Card <%= n %></div>
            <label>Judul<input name="menuCard<%= n %>Title" value="<%= card.title || '' %>" placeholder="Judul menu"></label>
            <label>Deskripsi<input name="menuCard<%= n %>Desc" value="<%= card.desc || '' %>" placeholder="Deskripsi singkat"></label>
            <label>Link Tujuan<input name="menuCard<%= n %>Link" value="<%= card.link || '' %>" placeholder="https://..."></label>
            <label>Image URL<input name="menuCard<%= n %>Image" value="<%= card.image || '' %>" placeholder="https://domain/banner.jpg"></label>
            <label>Upload Gambar<input type="file" name="menuCard<%= n %>Image" accept="image/*"></label>
            <div class="preview-row">
              <% if(card.image){ %><img src="<%= card.image %>" alt="preview"><% } %>
              <span>Rekomendasi 900x320</span>
            </div>
          </section>
        <% } %>
      </div>

      <button class="save-btn"><i class="fa-solid fa-floppy-disk"></i> Simpan Semua Setting</button>
    </form>

    <form action="/itsiregar8008/message/add" method="POST" enctype="multipart/form-data" class="admin-card">
      <h2>Pesan Inbox Member</h2>
      <div class="admin-grid">
        <label>Kategori<input name="category" placeholder="INFO / PROMO / UPDATE"></label>
        <label>Judul Pesan<input name="title" placeholder="Judul pesan" required></label>
        <label>Image URL<input name="imageUrl" placeholder="Opsional: https://..."></label>
        <label>Upload Gambar Pesan<input type="file" name="messageImageFile" accept="image/*"></label>
        <label>Link<input name="link" placeholder="Opsional: https://..."></label>
        <label class="full">Isi Pesan<textarea name="message" placeholder="Tulis pesan untuk member" required></textarea></label>
      </div>
      <button class="save-btn"><i class="fa-solid fa-paper-plane"></i> Kirim ke Inbox</button>
    </form>

    <section class="admin-card">
      <div class="card-head">
        <h2>Riwayat Pesan</h2>
        <form action="/itsiregar8008/messages/clear" method="POST"><button class="delete-btn">Hapus Semua</button></form>
      </div>
      <div class="message-admin-list">
        <% if(messages.length){ messages.forEach(msg=>{ %>
          <div class="message-admin-item">
            <div>
              <small><%= msg.category || 'INFO' %> • <%= msg.date || '' %></small>
              <strong><%= msg.title %></strong>
              <p><%= msg.message %></p>
            </div>
            <form action="/itsiregar8008/message/delete/<%= msg.id %>" method="POST"><button class="delete-btn">Hapus</button></form>
          </div>
        <% }) } else { %><div class="empty-box">Belum ada pesan.</div><% } %>
      </div>
    </section>
  </main>
</div>
