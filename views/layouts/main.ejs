<!DOCTYPE html>
<html lang="id">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"
/>

<title>
<%= settings?.siteName || title || 'OMTOGEL' %>
</title>

<meta
name="description"
content="<%= settings?.siteDescription || 'OMTOGEL Premium App' %>"
/>

<meta
name="keywords"
content="<%= settings?.siteKeywords || 'omtogel' %>"
/>

<meta
name="theme-color"
content="#050505"
/>

<meta
property="og:title"
content="<%= settings?.siteName || 'OMTOGEL' %>"
/>

<meta
property="og:description"
content="<%= settings?.siteDescription || 'OMTOGEL Premium App' %>"
/>

<meta
property="og:image"
content="<%= settings?.logoUrl || settings?.heroImageUrl || '' %>"
/>

<% if(settings?.faviconUrl || settings?.logoUrl){ %>

<link
rel="icon"
href="<%= settings.faviconUrl || settings.logoUrl %>"
/>

<% } %>

<link
rel="stylesheet"
href="/assets/css/style.css"
/>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
/>

<script src="/socket.io/socket.io.js"></script>

<style>

/* =========================
RESET
========================= */

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html,
body{

width:100%;
height:100%;

overflow:hidden;

background:#000;

font-family:
Arial,
sans-serif;

}

/* =========================
WEBVIEW FULL
========================= */

.mobile-webview{

position:fixed;

top:0;
left:0;

width:100%;
height:100%;

background:#000;

z-index:1;

}

.mobile-webview iframe{

width:100%;
height:100%;

border:none;

background:#000;

}

/* =========================
BOTTOM MENU
========================= */

.bottom-nav{

position:fixed;

left:0;
right:0;
bottom:0;

width:100%;

height:78px;

background:
linear-gradient(
to bottom,
#e7e7e7,
#9f9f9f
);

border-top:
1px solid rgba(255,255,255,.45);

display:flex;

align-items:center;

justify-content:space-around;

z-index:999999999;

backdrop-filter:blur(10px);

box-shadow:
0 -5px 20px rgba(0,0,0,.45);

padding-bottom:
env(safe-area-inset-bottom);

}

/* ITEM */

.bottom-item{

width:20%;

height:100%;

display:flex;

flex-direction:column;

align-items:center;

justify-content:center;

text-decoration:none;

color:#111;

font-size:11px;

font-weight:800;

gap:4px;

letter-spacing:.3px;

}

.bottom-item i{

font-size:22px;

color:#111;

}

/* CENTER */

.bottom-center{

width:72px;
height:72px;

border-radius:50%;

margin-top:-24px;

background:
linear-gradient(
145deg,
#f8f8f8,
#9a9a9a
);

border:
4px solid #111;

display:flex;

align-items:center;

justify-content:center;

box-shadow:
0 0 18px rgba(255,255,255,.28);

cursor:pointer;

}

.bottom-center img{

width:38px;
height:38px;

object-fit:contain;

}

/* MOBILE */

@media(max-width:768px){

.bottom-nav{

height:74px;

}

.bottom-item i{

font-size:20px;

}

.bottom-item span{

font-size:10px;

}

.bottom-center{

width:66px;
height:66px;

}

.bottom-center img{

width:34px;
height:34px;

}

}

</style>

</head>

<body
style="
--primary:<%= settings?.primaryColor || '#c0c0c0' %>;
--accent:<%= settings?.accentColor || '#f5c542' %>;
"
>

<!-- =========================
WEBVIEW
========================= -->

<div class="mobile-webview">

<iframe
src="<%= settings?.mobileWebviewUrl || '/home' %>"
allowfullscreen
loading="lazy"
></iframe>

</div>

<!-- =========================
BOTTOM MENU
========================= -->

<div class="bottom-nav">

<a
href="<%= settings?.bottomMenu1Link || '#' %>"
class="bottom-item"
>

<i class="fas fa-bars"></i>

<span>
<%= settings?.bottomMenu1Text || 'MENU' %>
</span>

</a>

<a
href="<%= settings?.bottomMenu2Link || '#' %>"
class="bottom-item"
>

<i class="fas fa-tv"></i>

<span>
<%= settings?.bottomMenu2Text || 'LIVEDRAW' %>
</span>

</a>

<!-- CENTER REFRESH -->

<button
type="button"
class="bottom-center"
onclick="window.location.reload()"
>

<img
src="<%= settings?.logoUrl || '/images/logo.png' %>"
alt="logo"
/>

</button>

<a
href="<%= settings?.whatsappUrl || '#' %>"
class="bottom-item"
>

<i class="fab fa-whatsapp"></i>

<span>
WHATSAPP
</span>

</a>

<a
href="<%= settings?.bottomMenu4Link || '#' %>"
class="bottom-item"
>

<i class="fas fa-envelope"></i>

<span>
<%= settings?.bottomMenu4Text || 'INBOX' %>
</span>

</a>

</div>

<script>

/* =========================
SOCKET
========================= */

try{

const socket = io();

socket.on(
'messages:update',
(data)=>{

const badge =
document.querySelector(
'[data-inbox-badge]'
);

if(badge){

badge.textContent =
data.unread || 0;

badge.style.display =
(data.unread || 0) > 0
? 'grid'
: 'none';

}

});

}catch(e){}

/* =========================
ANTI DOUBLE TAP ZOOM
========================= */

document.addEventListener(
'touchstart',
function(event){

if(event.touches.length > 1){

event.preventDefault();

}

},
{ passive:false }
);

</script>

</body>
</html>
