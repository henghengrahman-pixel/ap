<!doctype html><html lang="id"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"><title><%= (typeof title !== 'undefined' && title) || settings?.siteName || 'OMTOGEL' %></title><meta name="description" content="<%= settings?.siteDescription || '' %>"><meta name="keywords" content="<%= settings?.siteKeywords || '' %>"><meta name="theme-color" content="<%= settings?.themeColor || '#050505' %>"><% if(settings?.faviconUrl || settings?.logoUrl){ %><link rel="icon" href="<%= settings.faviconUrl || settings.logoUrl %>"><% } %><link rel="manifest" href="/manifest.json"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"><link rel="stylesheet" href="/assets/css/style.css"><script>window.__APP_SETTINGS__=<%- JSON.stringify(settings || {}) %>;window.__CSRF_TOKEN__='<%= csrfToken || '' %>';</script><script src="/socket.io/socket.io.js" defer></script><script src="/assets/js/app.js" defer></script></head><body style="--theme:<%= settings?.themeColor || '#050505' %>;--accent:<%= settings?.accentColor || '#c0c0c0' %>;--gold:<%= settings?.goldColor || '#f5c542' %>"><%- body %></body></html>
